{
  "rules": {
    ".read": false,
    ".write": false,

    "licenses": {
      ".read": false,
      ".write": false
    },
    "spec_updater_licenses": {
      ".read": false,
      ".write": false
    },

    "app_versions": {
      "$appId": {
        ".read": "auth != null",
        ".write": "auth.token.tier === 'admin' || auth.token.tier === 'dev'",
        ".indexOn": ["latest_version", "updated_at"]
      }
    },

    "admin_users": {
      ".read": false,
      ".write": false
    },
    "dev_users": {
      ".read": false,
      ".write": false
    },

    "tenants": {
      "$tenantId": {
        "licenses": {
          "$appId": {
            "$licenseKey": {
              ".read": "auth.token.tenant_id === $tenantId && auth.token.app_id === $appId && auth != null",
              ".write": "auth.token.tenant_id === $tenantId && (auth.token.tier === 'admin' || auth.token.tier === 'dev' || (auth.token.tier === 'user' && auth.token.app_id === $appId && auth.token.license_key === $licenseKey && (!data.exists() || newData.child('license_key').val() === data.child('license_key').val())))",
              ".indexOn": ["email", "status", "plan", "source"]
            }
          }
        },

        "admin_users": {
          ".read": false,
          ".write": false,
          "$userId": {
            ".read": false,
            ".write": false
          }
        },

        "dev_users": {
          ".read": false,
          ".write": false,
          "$userId": {
            ".read": false,
            ".write": false
          }
        },

        "users": {
          ".read": "auth.token.tenant_id === $tenantId && (auth.token.tier === 'admin' || auth.token.tier === 'dev')",
          "$userId": {
            ".read": "auth.token.tenant_id === $tenantId && (auth.token.tier === 'admin' || auth.token.tier === 'dev' || auth.token.user_id === $userId)",
            ".write": "auth.token.tenant_id === $tenantId && (auth.token.tier === 'admin' || auth.token.tier === 'dev' || auth.token.user_id === $userId)"
          }
        },

        "devices": {
          ".read": "auth.token.tenant_id === $tenantId && (auth.token.tier === 'admin' || auth.token.tier === 'dev')",
          ".indexOn": ["license_key", "user_id", "status", "last_seen"],
          "$deviceId": {
            ".read": "auth.token.tenant_id === $tenantId && (auth.token.tier === 'admin' || auth.token.tier === 'dev' || data.child('user_id').val() === auth.token.user_id)",
            ".write": "auth.token.tenant_id === $tenantId && (auth.token.tier === 'admin' || auth.token.tier === 'dev' || !data.exists() || data.child('user_id').val() === auth.token.user_id)"
          }
        },

        "events": {
          "$appId": {
            "$month": {
              ".read": "auth.token.tenant_id === $tenantId && (auth.token.tier === 'admin' || auth.token.tier === 'dev')",
              ".write": "auth.token.tenant_id === $tenantId"
            }
          }
        },

        "errors": {
          "$appId": {
            "$month": {
              ".read": "auth.token.tenant_id === $tenantId && (auth.token.tier === 'admin' || auth.token.tier === 'dev')",
              ".write": "auth.token.tenant_id === $tenantId"
            }
          }
        },

        "metrics": {
          ".read": "auth.token.tenant_id === $tenantId && (auth.token.tier === 'admin' || auth.token.tier === 'dev')",
          ".indexOn": ["date", "user_id"],
          "$deviceId": {
            ".read": "auth.token.tenant_id === $tenantId && (auth.token.tier === 'admin' || auth.token.tier === 'dev')",
            ".write": "auth.token.tenant_id === $tenantId"
          }
        },

        "cheat_sheet_editors": {
          ".read": false,
          ".write": false,
          "$userId": {
            ".read": "auth.token.tenant_id === $tenantId && (auth.token.tier === 'admin' || auth.token.tier === 'dev' || auth.token.user_id === $userId)",
            ".write": false
          }
        }
      }
    },

    "cheat_sheet_editors": {
      ".read": false,
      ".write": false
    },

    "users": {
      ".read": false,
      ".write": false
    },

    "devices": {
      ".read": false,
      ".write": false
    },

    "events": {
      ".read": false,
      ".write": false
    },

    "errors": {
      ".read": false,
      ".write": false
    },

    "metrics": {
      ".read": false,
      ".write": false
    },

    "feature_flags": {
      ".read": "auth != null",
      ".write": "auth.token.tier === 'admin' || auth.token.tier === 'dev'"
    },

    "force_update": {
      "$deviceId": {
        ".read": "auth != null",
        ".write": "auth.token.tier === 'admin' || auth.token.tier === 'dev'"
      }
    },

    "config": {
      ".read": "auth != null",
      ".write": "auth.token.tier === 'admin' || auth.token.tier === 'dev'"
    },

    "project_tags": {
      "$hash": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "tag_vocabulary": {
      "$fieldKey": {
        ".read": "auth != null",
        ".write": "auth.token.tier === 'admin' || auth.token.tier === 'dev'"
      }
    }
  }
}
