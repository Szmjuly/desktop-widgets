                            <!-- Max Files -->
                            <StackPanel Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Max Files" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}"/>
                                    <TextBlock x:Name="DQ_MaxFilesValue" Grid.Column="1" Text="200" FontSize="13" Foreground="{StaticResource PrimaryBrush}"/>
                                </Grid>
                                <TextBlock Text="Maximum number of files to display (50-500)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,6"/>
                                <Slider x:Name="DQ_MaxFilesSlider" Minimum="50" Maximum="500" TickFrequency="50" IsSnapToTickEnabled="True"
                                        ValueChanged="DQ_MaxFilesSlider_Changed" Style="{StaticResource StyledSlider}"/>
