                            </StackPanel>
                            
                            <ToggleButton x:Name="LivingWidgetsModeToggle" Style="{StaticResource ToggleSwitch}"
                                          Grid.Column="1"
                                          Width="50"
                                          Height="28"
                                          VerticalAlignment="Center"
                                          Checked="LivingWidgetsModeToggle_Checked"
                                          Unchecked="LivingWidgetsModeToggle_Unchecked"
                                          Cursor="Hand">
                            </ToggleButton>
                        </Grid>
                    </Border>

                    <!-- Notification Duration Section -->
                    <Border Background="{StaticResource SurfaceBrush}" 
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Notification Duration" 
                                       FontSize="16" 
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,0,8"/>
                            
                            <TextBlock Text="How long balloon notifications stay visible" 
                                       FontSize="12" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,12"/>
                            
                            <!-- Radio buttons for preset durations -->
                            <StackPanel x:Name="NotificationDurationStack" Margin="0,0,0,8">
                                <RadioButton x:Name="NotificationShortRadio"
                                             Content="Short (2 seconds)"
                                             FontSize="13"
                                             Foreground="{StaticResource TextBrush}"
                                             Margin="0,0,0,4"
                                             Checked="NotificationDurationRadio_Checked"/>
                                
                                <RadioButton x:Name="NotificationMediumRadio"
                                             Content="Medium (3 seconds)"
                                             FontSize="13"
                                             Foreground="{StaticResource TextBrush}"
                                             Margin="0,0,0,4"
                                             Checked="NotificationDurationRadio_Checked"/>
                                
                                <RadioButton x:Name="NotificationLongRadio"
                                             Content="Long (5 seconds)"
                                             FontSize="13"
                                             Foreground="{StaticResource TextBrush}"
                                             Margin="0,0,0,4"
                                             Checked="NotificationDurationRadio_Checked"/>
                                
                                <RadioButton x:Name="NotificationDisabledRadio"
                                             Content="Disabled (no notifications)"
                                             FontSize="13"
                                             Foreground="{StaticResource TextBrush}"
                                             Checked="NotificationDurationRadio_Checked"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- Smart Project Search Panel -->
                    <Border x:Name="SmartProjectSearchPanel" Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="20" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource ThinScrollViewer}">
                            <StackPanel>
                                <!-- Smart Project Search Section -->
                                <Border Background="#18FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Smart Project Search" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Text="Controls query behavior for the Smart Project Search widget." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Attach mode" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                                                <TextBlock Text="Embed Smart Project Search inside the Search Overlay. This disables the widget-launcher Smart Search toggle while active." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <ToggleButton x:Name="SmartProjectSearchAttachModeToggle" Style="{StaticResource ToggleSwitch}" Grid.Column="1" Width="50" Height="28" VerticalAlignment="Center" IsChecked="False"
                                                          Checked="SmartProjectSearchAttachModeToggle_Changed" Unchecked="SmartProjectSearchAttachModeToggle_Changed" Cursor="Hand">
                                            </ToggleButton>
                                        </Grid>

                                        <TextBlock Text="Latest query mode" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                                        <StackPanel Margin="12,0,0,10">
                                            <RadioButton x:Name="SmartSearchLatestListRadio"
                                                         Content="Newest-first list"
                                                         FontSize="12"
                                                         Foreground="{StaticResource TextBrush}"
                                                         Margin="0,0,0,4"
                                                         Checked="SmartSearchLatestMode_Changed"/>
                                            <RadioButton x:Name="SmartSearchLatestSingleRadio"
                                                         Content="Single newest result"
                                                         FontSize="12"
                                                         Foreground="{StaticResource TextBrush}"
                                                         Checked="SmartSearchLatestMode_Changed"/>
                                        </StackPanel>

                                        <TextBlock Text="Searchable file types" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Text="Comma-separated keywords/extensions. Example: doc, docx, pdf, txt, dwg, rvt, excel, png, jpeg, msg"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,6"/>
                                        <TextBox x:Name="SmartSearchFileTypesInput"
                                                 Background="#22FFFFFF"
                                                 BorderBrush="{StaticResource BorderBrush}"
                                                 Foreground="{StaticResource TextBrush}"
                                                 Padding="8,6"
                                                 LostFocus="SmartSearchFileTypesInput_LostFocus"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- Widget Launcher Panel -->
                    <Border x:Name="WidgetLauncherPanel" Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="20" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource ThinScrollViewer}">
                            <StackPanel>
                                <!-- Widget Launcher Widgets Section -->
                                <Border Background="#18FFFFFF" 
                                        BorderBrush="#22FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="16"
                                        Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Widget Launcher Widgets" 
                                                   FontSize="16" 
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Enable or disable widgets available in the widget launcher" 
                                                   FontSize="12" 
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,0,0,16"/>

                                        <StackPanel Margin="0,0,0,14">
                                            <TextBlock Text="Max visible widgets before scroll"
                                                       FontSize="13"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource TextBrush}"
                                                       Margin="0,0,0,4"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="Few"
                                                           FontSize="10"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"/>

                                                <Slider x:Name="WidgetLauncherMaxVisibleWidgetsSlider"
                                                       Grid.Column="1"
                                                       Minimum="1"
                                                       Maximum="12"
                                                       TickFrequency="1"
                                                       IsSnapToTickEnabled="True"
                                                       Value="4"
                                                       ValueChanged="WidgetLauncherMaxVisibleWidgetsSlider_Changed"
                                                       VerticalAlignment="Center"
                                                       Style="{StaticResource StyledSlider}"/>

                                                <TextBlock x:Name="WidgetLauncherMaxVisibleWidgetsValueText"
                                                           Grid.Column="2"
                                                           Text="4"
                                                           FontSize="11"
                                                           FontWeight="Medium"
                                                           Foreground="{StaticResource TextBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0"/>
                                            </Grid>
                                        </StackPanel>
                                        
                                        <!-- Widget toggles (generated dynamically from WidgetRegistry) -->
                                        <StackPanel x:Name="WidgetTogglesContainer"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                    
                    <!-- Updates Panel -->
                    <Border x:Name="UpdatesPanel" Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="20" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource ThinScrollViewer}">
                            <StackPanel>
                                <Border Background="#18FFFFFF" 
                                        BorderBrush="#22FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="Update Settings" 
                                                   FontSize="16" 
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Configure automatic update checking and installation" 
                                                   FontSize="12" 
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,0,0,16"/>
                                        
                                        <!-- Auto Update Check Toggle -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Auto Check for Updates" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                                                <TextBlock Text="Periodically check for new versions" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                            <ToggleButton x:Name="AutoUpdateCheckToggle" Style="{StaticResource ToggleSwitch}" Grid.Column="1" Width="50" Height="28" VerticalAlignment="Center" IsChecked="True"
                                                          Checked="AutoUpdateCheckToggle_Changed" Unchecked="AutoUpdateCheckToggle_Changed" Cursor="Hand">
                                            </ToggleButton>
                                        </Grid>
                                        
                                        <!-- Auto Install Toggle -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Auto Install Updates" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                                                <TextBlock Text="Automatically download and prompt to install" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                            <ToggleButton x:Name="AutoUpdateInstallToggle" Style="{StaticResource ToggleSwitch}" Grid.Column="1" Width="50" Height="28" VerticalAlignment="Center" IsChecked="False"
                                                          Checked="AutoUpdateInstallToggle_Changed" Unchecked="AutoUpdateInstallToggle_Changed" Cursor="Hand">
                                            </ToggleButton>
                                        </Grid>
                                        
                                        <!-- Check Frequency -->
                                        <StackPanel Margin="0,0,0,0">
                                            <TextBlock Text="Check Frequency" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                            <ComboBox x:Name="UpdateFrequencyCombo" 
                                                      SelectionChanged="UpdateFrequencyCombo_SelectionChanged"
                                                      FontSize="13" Padding="10,8" Cursor="Hand">
                                                <ComboBox.Style>
                                                    <Style TargetType="ComboBox">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ComboBox">
                                                                    <Grid>
                                                                        <ToggleButton x:Name="ToggleButton"
                                                                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                                                      Focusable="False"
                                                                                      ClickMode="Press">
                                                                            <ToggleButton.Template>
                                                                                <ControlTemplate TargetType="ToggleButton">
                                                                                    <Border Background="#333333" CornerRadius="6" BorderBrush="#555555" BorderThickness="1" Padding="10,8">
                                                                                        <Grid>
                                                                                            <Grid.ColumnDefinitions>
                                                                                                <ColumnDefinition Width="*"/>
                                                                                                <ColumnDefinition Width="Auto"/>
                                                                                            </Grid.ColumnDefinitions>
                                                                                            <ContentPresenter Grid.Column="0"/>
                                                                                            <TextBlock Grid.Column="1" Text="▾" Foreground="#80FFFFFF" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                                                        </Grid>
                                                                                    </Border>
                                                                                </ControlTemplate>
                                                                            </ToggleButton.Template>
                                                                        </ToggleButton>
                                                                        <ContentPresenter x:Name="ContentSite"
                                                                                          IsHitTestVisible="False"
                                                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                                                          Margin="12,8,28,8"
                                                                                          VerticalAlignment="Center"
                                                                                          HorizontalAlignment="Left">
                                                                            <ContentPresenter.Resources>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="White"/>
                                                                                </Style>
                                                                            </ContentPresenter.Resources>
                                                                        </ContentPresenter>
                                                                        <Popup x:Name="Popup"
                                                                               Placement="Bottom"
                                                                               IsOpen="{TemplateBinding IsDropDownOpen}"
                                                                               AllowsTransparency="True"
                                                                               Focusable="False"
                                                                               PopupAnimation="Slide">
                                                                            <Border Background="#2A2A2A" CornerRadius="6" BorderBrush="#555555" BorderThickness="1" 
                                                                                    MinWidth="{TemplateBinding ActualWidth}" Padding="4" Margin="0,2,0,0">
                                                                                <StackPanel IsItemsHost="True"/>
                                                                            </Border>
                                                                        </Popup>
                                                                    </Grid>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ComboBox.Style>
                                                <ComboBox.ItemContainerStyle>
                                                    <Style TargetType="ComboBoxItem">
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Padding" Value="10,6"/>
                                                        <Setter Property="Cursor" Value="Hand"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ComboBoxItem">
                                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsHighlighted" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background" Value="#007ACC"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ComboBox.ItemContainerStyle>
                                                <ComboBoxItem Content="Every 1 hour" Tag="60"/>
                                                <ComboBoxItem Content="Every 6 hours" Tag="360"/>
                                                <ComboBoxItem Content="Every 12 hours" Tag="720"/>
                                                <ComboBoxItem Content="Every 24 hours" Tag="1440"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                    
                    <!-- Quick Tasks Panel -->
                    <Border x:Name="QuickTasksPanel" Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="20" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource ThinScrollViewer}">
                            <StackPanel>
                    
                    <!-- Display Settings -->
                    <Border Background="#18FFFFFF" 
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Display" 
                                       FontSize="16" 
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,0,12"/>
                            
                            <!-- Show Completed Tasks -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Show Completed Tasks" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                                    <TextBlock Text="Display completed tasks in the list (with strikethrough)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleButton x:Name="QT_ShowCompletedToggle" Style="{StaticResource ToggleSwitch}" Grid.Column="1" Width="50" Height="28" VerticalAlignment="Center"
                                              Checked="QT_ShowCompletedToggle_Changed" Unchecked="QT_ShowCompletedToggle_Changed" Cursor="Hand">
                                </ToggleButton>
                            </Grid>
                            
                            <!-- Compact Mode -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Compact Mode" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                                    <TextBlock Text="Tighter spacing to fit more tasks on screen" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleButton x:Name="QT_CompactModeToggle" Style="{StaticResource ToggleSwitch}" Grid.Column="1" Width="50" Height="28" VerticalAlignment="Center"
                                              Checked="QT_CompactModeToggle_Changed" Unchecked="QT_CompactModeToggle_Changed" Cursor="Hand">
                                </ToggleButton>
                            </Grid>
                            
                            <!-- Completed Task Opacity -->
                            <TextBlock Text="Completed Task Opacity" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Faded" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Slider x:Name="QT_CompletedOpacitySlider" Grid.Column="1" Minimum="0.2" Maximum="1.0" Value="0.5"
                                        TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="QT_CompletedOpacitySlider_Changed" VerticalAlignment="Center"
                                        Style="{StaticResource StyledSlider}"/>
                                <TextBlock Grid.Column="2" Text="Solid" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <!-- Behavior Settings -->
                    <Border Background="#18FFFFFF" 
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Behavior" 
                                       FontSize="16" 
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,0,12"/>
                            
                            <!-- Auto Carry-Over -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Auto Carry-Over" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                                    <TextBlock Text="Automatically carry incomplete tasks to the next day" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleButton x:Name="QT_AutoCarryOverToggle" Style="{StaticResource ToggleSwitch}" Grid.Column="1" Width="50" Height="28" VerticalAlignment="Center"
                                              Checked="QT_AutoCarryOverToggle_Changed" Unchecked="QT_AutoCarryOverToggle_Changed" Cursor="Hand">
                                </ToggleButton>
                            </Grid>
                            
                            <!-- Default Priority -->
                            <TextBlock Text="Default Priority" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                            <TextBlock Text="Priority assigned to new tasks" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                            <StackPanel x:Name="QT_DefaultPriorityStack" Orientation="Horizontal" Margin="0,0,0,16">
                                <RadioButton x:Name="QT_PriorityLow" Content="Low" GroupName="QTPriority" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,16,0" Checked="QT_DefaultPriority_Changed" Cursor="Hand"/>
                                <RadioButton x:Name="QT_PriorityNormal" Content="Normal" GroupName="QTPriority" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,16,0" Checked="QT_DefaultPriority_Changed" Cursor="Hand" IsChecked="True"/>
                                <RadioButton x:Name="QT_PriorityHigh" Content="High" GroupName="QTPriority" FontSize="12" Foreground="{StaticResource TextBrush}" Checked="QT_DefaultPriority_Changed" Cursor="Hand"/>
                            </StackPanel>
                            
                            <!-- Sort Mode -->
                            <TextBlock Text="Sort Order" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                            <TextBlock Text="How tasks are ordered in the list" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                            <StackPanel x:Name="QT_SortModeStack" Orientation="Horizontal" Margin="0,0,0,4">
                                <RadioButton x:Name="QT_SortManual" Content="Manual" GroupName="QTSort" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,16,0" Checked="QT_SortMode_Changed" Cursor="Hand" IsChecked="True"/>
                                <RadioButton x:Name="QT_SortPriority" Content="Priority" GroupName="QTSort" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,16,0" Checked="QT_SortMode_Changed" Cursor="Hand"/>
                                <RadioButton x:Name="QT_SortCreated" Content="Created" GroupName="QTSort" FontSize="12" Foreground="{StaticResource TextBrush}" Checked="QT_SortMode_Changed" Cursor="Hand"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- Categories -->
                    <Border Background="#18FFFFFF" 
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16">
