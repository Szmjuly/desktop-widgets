                            <TextBlock Text="Current Items" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="QL_ItemCountText" Text="Loading..." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                            
                            <StackPanel x:Name="QL_ItemsList" Margin="0,0,0,8"/>
                            
                            <!-- Clear All -->
                            <Button x:Name="QL_ClearAllButton" Content="Clear All Items" Padding="16,8" Cursor="Hand"
