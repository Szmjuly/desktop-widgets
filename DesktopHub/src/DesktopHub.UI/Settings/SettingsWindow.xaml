                                <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></TextBox.Resources>
                            </TextBox>
                        </StackPanel>
                    </Border>
                    
                    <!-- Sorting & Grouping -->
                    <Border Background="#18FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Sorting &amp; Grouping" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>
                            
                            <!-- Sort By -->
                            <TextBlock Text="Sort By" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <RadioButton x:Name="DQ_SortName" Content="Name" GroupName="DQSort" Foreground="{StaticResource TextBrush}" Margin="0,0,16,0" Checked="DQ_SortChanged" Cursor="Hand"/>
                                <RadioButton x:Name="DQ_SortDate" Content="Date" GroupName="DQSort" Foreground="{StaticResource TextBrush}" Margin="0,0,16,0" Checked="DQ_SortChanged" Cursor="Hand"/>
                                <RadioButton x:Name="DQ_SortType" Content="Type" GroupName="DQSort" Foreground="{StaticResource TextBrush}" Margin="0,0,16,0" Checked="DQ_SortChanged" Cursor="Hand"/>
                                <RadioButton x:Name="DQ_SortSize" Content="Size" GroupName="DQSort" Foreground="{StaticResource TextBrush}" Checked="DQ_SortChanged" Cursor="Hand"/>
                            </StackPanel>
                            
                            <!-- Group By -->
                            <TextBlock Text="Group By" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                <RadioButton x:Name="DQ_GroupNone" Content="None" GroupName="DQGroup" Foreground="{StaticResource TextBrush}" Margin="0,0,16,0" Checked="DQ_GroupChanged" Cursor="Hand"/>
                                <RadioButton x:Name="DQ_GroupCategory" Content="Category" GroupName="DQGroup" Foreground="{StaticResource TextBrush}" Margin="0,0,16,0" Checked="DQ_GroupChanged" Cursor="Hand"/>
                                <RadioButton x:Name="DQ_GroupExt" Content="Extension" GroupName="DQGroup" Foreground="{StaticResource TextBrush}" Margin="0,0,16,0" Checked="DQ_GroupChanged" Cursor="Hand"/>
                                <RadioButton x:Name="DQ_GroupSubfolder" Content="Subfolder" GroupName="DQGroup" Foreground="{StaticResource TextBrush}" Checked="DQ_GroupChanged" Cursor="Hand"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- Behavior -->
                    <Border Background="#18FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Behavior" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>
                            
                            <!-- Auto-open last project -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Remember Last Project" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                                    <TextBlock Text="Auto-open the last selected project on launch" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleButton x:Name="DQ_AutoOpenToggle" Style="{StaticResource ToggleSwitch}" Grid.Column="1" Width="50" Height="28" VerticalAlignment="Center"
                                              Checked="DQ_AutoOpenToggle_Changed" Unchecked="DQ_AutoOpenToggle_Changed" Cursor="Hand">
                                </ToggleButton>
                            </Grid>
                            
                            <!-- Recent Files Count -->
                            <StackPanel Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Recent Files Count" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}"/>
                                    <TextBlock x:Name="DQ_RecentCountValue" Grid.Column="1" Text="10" FontSize="13" Foreground="{StaticResource PrimaryBrush}"/>
                                </Grid>
                                <TextBlock Text="Number of recently opened files to remember (0 = disabled)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,6"/>
                                <Slider x:Name="DQ_RecentCountSlider" Minimum="0" Maximum="20" TickFrequency="1" IsSnapToTickEnabled="True"
                                        ValueChanged="DQ_RecentCountSlider_Changed" Style="{StaticResource StyledSlider}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                    
                    <!-- Frequent Projects Panel -->
                    <Border x:Name="FrequentProjectsPanel" Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="20" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource ThinScrollViewer}">
                            <StackPanel>
                    
                    <!-- Display Settings -->
                    <Border Background="#18FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Display" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>
                            
                            <!-- Max Projects Shown -->
                            <StackPanel Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Projects Shown" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}"/>
                                    <TextBlock x:Name="FP_MaxShownValue" Grid.Column="1" Text="5" FontSize="13" Foreground="{StaticResource PrimaryBrush}"/>
                                </Grid>
                                <TextBlock Text="Number of top projects displayed in the widget (1-10)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,6"/>
                                <Slider x:Name="FP_MaxShownSlider" Minimum="1" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True"
                                        ValueChanged="FP_MaxShownSlider_Changed" Style="{StaticResource StyledSlider}"/>
                            </StackPanel>
                            
                            <!-- Max Projects Saved -->
                            <StackPanel Margin="0,0,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Projects Tracked" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}"/>
                                    <TextBlock x:Name="FP_MaxSavedValue" Grid.Column="1" Text="20" FontSize="13" Foreground="{StaticResource PrimaryBrush}"/>
                                </Grid>
                                <TextBlock Text="Maximum number of projects to track launch counts for (5-50)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,6"/>
                                <Slider x:Name="FP_MaxSavedSlider" Minimum="5" Maximum="50" TickFrequency="5" IsSnapToTickEnabled="True"
                                        ValueChanged="FP_MaxSavedSlider_Changed" Style="{StaticResource StyledSlider}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- Layout -->
                    <Border Background="#18FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Layout" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>
                            
                            <!-- Grid Mode Toggle -->
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Grid Mode" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                                    <TextBlock Text="Display projects in a compact grid instead of a vertical list" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleButton x:Name="FP_GridModeToggle" Style="{StaticResource ToggleSwitch}" Grid.Column="1" Width="50" Height="28" VerticalAlignment="Center" IsChecked="False"
                                              Checked="FP_GridModeToggle_Changed" Unchecked="FP_GridModeToggle_Changed" Cursor="Hand">
                                </ToggleButton>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <!-- Data Management -->
                    <Border Background="#18FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Data Management" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="Manage your project launch history" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                            
                            <TextBlock x:Name="FP_StatsText" Text="Loading stats..." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                            
                            <!-- Reset Launch Data -->
                            <Button x:Name="FP_ResetDataButton" Content="Reset All Launch Data" Padding="16,8" Cursor="Hand"
                                    Click="FP_ResetData_Click"
                                    Background="#30FF5252" Foreground="#FF5252" BorderBrush="#40FF5252">
                                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
                    
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                    
                    <!-- Quick Launch Panel -->
                    <Border x:Name="QuickLaunchPanel" Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="20" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource ThinScrollViewer}">
                            <StackPanel>
                    
                    <!-- Layout -->
                    <Border Background="#18FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Layout" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>
                            
                            <!-- Horizontal Mode Toggle -->
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Horizontal Mode" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                                    <TextBlock Text="Display items in a horizontal row instead of a vertical list (max 5 visible before scrolling)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleButton x:Name="QL_HorizontalModeToggle" Style="{StaticResource ToggleSwitch}" Grid.Column="1" Width="50" Height="28" VerticalAlignment="Center" IsChecked="False"
                                              Checked="QL_HorizontalModeToggle_Changed" Unchecked="QL_HorizontalModeToggle_Changed" Cursor="Hand">
                                </ToggleButton>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <!-- Drag and Drop Info -->
                    <Border Background="#18FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Adding Items" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="You can add items to Quick Launch in several ways:" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                            
                            <StackPanel Margin="0,0,0,4">
                                <TextBlock FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6" TextWrapping="Wrap">
                                    <Run FontWeight="SemiBold" Text="Drag &amp; Drop:"/> 
                                    <Run Text="Drag files or folders from File Explorer directly onto the Quick Launch widget"/>
                                </TextBlock>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6" TextWrapping="Wrap">
                                    <Run FontWeight="SemiBold" Text="Browse:"/>
                                    <Run Text="Click the + button in the widget, then use the Browse button to pick a folder"/>
                                </TextBlock>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,0,0" TextWrapping="Wrap">
                                    <Run FontWeight="SemiBold" Text="Manual:"/>
                                    <Run Text="Type or paste any file path, folder path, or URL into the path field"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
