                            <!-- Max Scan Depth -->
                            <StackPanel Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Max Scan Depth" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}"/>
                                    <TextBlock x:Name="DQ_MaxDepthValue" Grid.Column="1" Text="3" FontSize="13" Foreground="{StaticResource PrimaryBrush}"/>
