                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Snap Grid" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}"/>
                                                <TextBlock Text="When enabled, the metrics widget participates in edge snapping and overlap prevention. When disabled, it floats freely." 
