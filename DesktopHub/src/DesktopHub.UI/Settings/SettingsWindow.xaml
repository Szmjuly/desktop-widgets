<Window x:Class="DesktopHub.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopHub Settings"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Width="800"
        Height="650"
        Topmost="True"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">
    
    <!-- Styles loaded from Styles/SharedStyles.xaml via App.xaml MergedDictionaries -->
    
    <!-- Glass effect container -->
    <Border x:Name="RootBorder" 
            Background="#C8181818" 
            CornerRadius="12" 
            BorderBrush="#442A2A2A" 
            BorderThickness="1">
        <Grid>
            <!-- Inner glass overlay for depth -->
            <Border x:Name="GlassOverlay"
                    Margin="2"
                    CornerRadius="10"
                    BorderThickness="1"
                    BorderBrush="#33FFFFFF"
                    Background="#14000000"
                    IsHitTestVisible="False"/>
            
            <!-- Content -->
            <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header (draggable) -->
            <Grid Grid.Row="0" Margin="0,0,0,20" Background="Transparent" MouseDown="Header_MouseDown" Cursor="Hand">
                <TextBlock Text="Settings" 
                           FontSize="24" 
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"/>
                <Button x:Name="CloseButton"
                        Content="✕"
                        Width="32"
                        Height="32"
                        HorizontalAlignment="Right"
                        Background="#22FFFFFF"
                        Foreground="{StaticResource TextBrush}"
                        BorderBrush="#22FFFFFF"
                        Click="CloseButton_Click"
                        Cursor="Hand"
                        Style="{StaticResource RoundedButton}"/>
            </Grid>
            
            <!-- Side Menu Layout -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Side Navigation Menu -->
                <Border Grid.Column="0" Background="#18FFFFFF" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Style="{StaticResource ThinScrollViewer}">
                    <StackPanel x:Name="NavigationMenu">
                        <RadioButton x:Name="GeneralMenuButton" Content="⚙️ General" IsChecked="True" Checked="MenuButton_Checked"
                                     GroupName="SettingsMenu" Margin="0,0,0,8" Padding="12,10" FontSize="14" FontWeight="Medium"
                                     Foreground="{StaticResource TextBrush}" Cursor="Hand">
                            <RadioButton.Style>
                                <Style TargetType="RadioButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="RadioButton">
                                                <Border x:Name="Border" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#33FFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </RadioButton.Style>
                        </RadioButton>
                        
                        <RadioButton x:Name="ShortcutsMenuButton" Content="⚡ Shortcuts" Checked="MenuButton_Checked" 
                                     GroupName="SettingsMenu" Margin="0,0,0,8" Padding="12,10" FontSize="14" FontWeight="Medium" 
                                     Foreground="{StaticResource TextBrush}" Cursor="Hand">
                            <RadioButton.Style>
                                <Style TargetType="RadioButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="RadioButton">
                                                <Border x:Name="Border" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#33FFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </RadioButton.Style>
                        </RadioButton>
                        
                        <RadioButton x:Name="AppearanceMenuButton" Content="🎨 Appearance" Checked="MenuButton_Checked"
                                     GroupName="SettingsMenu" Margin="0,0,0,8" Padding="12,10" FontSize="14" FontWeight="Medium"
                                     Foreground="{StaticResource TextBrush}" Cursor="Hand">
                            <RadioButton.Style>
                                <Style TargetType="RadioButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="RadioButton">
                                                <Border x:Name="Border" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#33FFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </RadioButton.Style>
                        </RadioButton>

                        <!-- Widget-specific nav items (generated dynamically from WidgetRegistry) -->
                        <StackPanel x:Name="WidgetNavMenuContainer"/>

                        <RadioButton x:Name="TagsMenuButton" Content="🏷️ Tags" Checked="MenuButton_Checked"
                                     GroupName="SettingsMenu" Margin="0,0,0,8" Padding="12,10" FontSize="14" FontWeight="Medium"
                                     Foreground="{StaticResource TextBrush}" Cursor="Hand">
                            <RadioButton.Style>
                                <Style TargetType="RadioButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="RadioButton">
                                                <Border x:Name="Border" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#33FFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </RadioButton.Style>
                        </RadioButton>
                        
                        <RadioButton x:Name="UpdatesMenuButton" Content="🔄 Updates" Checked="MenuButton_Checked"
                                     GroupName="SettingsMenu" Margin="0,0,0,8" Padding="12,10" FontSize="14" FontWeight="Medium"
                                     Foreground="{StaticResource TextBrush}" Cursor="Hand">
                            <RadioButton.Style>
                                <Style TargetType="RadioButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="RadioButton">
                                                <Border x:Name="Border" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#33FFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </RadioButton.Style>
                        </RadioButton>
                    </StackPanel>
                    </ScrollViewer>
                </Border>
                
                <!-- Content Area -->
                <Grid Grid.Column="1">
                    <!-- Shortcuts Panel -->
                    <Border x:Name="ShortcutsPanel" Background="{StaticResource SurfaceBrush}" 
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="20" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource ThinScrollViewer}">
                            <StackPanel>
                    <!-- Close Shortcut Section -->
                    <Border Background="{StaticResource SurfaceBrush}" 
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Widget Close Shortcut" 
                                       FontSize="16" 
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,0,8"/>
                            
                            <TextBlock Text="Shortcut key to close overlay and widget windows" 
                                       FontSize="12" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,12"/>
                            
                            <!-- Close Shortcut Display -->
                            <Border x:Name="CloseShortcutBox"
                                    Background="#22FFFFFF"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12"
                                    Margin="0,0,0,12"
                                    Cursor="Hand"
                                    MouseDown="CloseShortcutBox_MouseDown">
                                <Grid>
                                    <TextBlock x:Name="CloseShortcutText"
                                               Text="Esc"
                                               FontSize="14"
                                               FontWeight="Medium"
                                               Foreground="{StaticResource TextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="CloseShortcutRecordingText"
                                               Text="Press a key combination..."
                                               FontSize="14"
                                               FontStyle="Italic"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Center"
                                               Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                            
                            <Button x:Name="ResetCloseShortcutButton"
                                    Content="Reset to Default (Esc)"
                                    Padding="12,8"
                                    Background="#22FFFFFF"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    Click="ResetCloseShortcutButton_Click"
                                    Cursor="Hand"
                                    Style="{StaticResource RoundedButton}"/>

                            <Border x:Name="CloseShortcutTypingWarning"
                                    Background="#332B1B00"
                                    BorderBrush="#665A3A00"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10"
                                    Margin="0,12,0,0"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="CloseShortcutTypingWarningText"
                                           TextWrapping="Wrap"
                                           FontSize="12"
                                           Foreground="#F3D6A2"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Hotkey Groups Section -->
                    <Border Background="#18FFFFFF" 
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Hotkey Groups" 
                                       FontSize="16" 
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Assign widgets to hotkey groups. Each widget belongs to one group. Click a hotkey box then press your key combo to set it." 
                                       FontSize="12" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,16"/>
                            <!-- Groups are built in code-behind via RebuildHotkeyGroupsPanel -->
                            <StackPanel x:Name="HotkeyGroupsPanel"/>
                        </StackPanel>
                    </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                    
                    <!-- Appearance Panel -->
                    <Border x:Name="AppearancePanel" Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="20" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource ThinScrollViewer}">
                            <StackPanel>
                    
                    <!-- Window Transparency Section -->
                    <Border Background="#18FFFFFF" 
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Window Transparency" 
                                       FontSize="16" 
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,0,12"/>
                            
                            <!-- Settings Window Transparency -->
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Settings Window" 
                                           FontSize="13" 
                                           FontWeight="Medium"
                                           Foreground="{StaticResource TextBrush}"
                                           VerticalAlignment="Center"/>
                                
                                <Button x:Name="LinkSettingsButton"
                                        HorizontalAlignment="Right"
                                        Width="24"
                                        Height="24"
                                        Background="#22FFFFFF"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        Click="LinkSettingsButton_Click"
                                        Cursor="Hand"
                                        ToolTip="Link to other sliders">
                                    <Grid>
                                        <TextBlock Text="&#x1F513;" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="4"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                            
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0"
                                          Text="Transparent"
                                          FontSize="10"
                                          Foreground="{StaticResource TextSecondaryBrush}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0"/>
                                
                                <Slider x:Name="SettingsTransparencySlider"
                                       Grid.Column="1"
                                       Minimum="0.4"
                                       Maximum="0.95"
                                       Value="0.78"
                                       IsSnapToTickEnabled="False"
                                       SmallChange="0.01"
                                       LargeChange="0.05"
                                       ValueChanged="SettingsTransparencySlider_ValueChanged"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource StyledSlider}"/>
                                
                                <TextBlock Grid.Column="2"
                                          Text="Opaque"
                                          FontSize="10"
                                          Foreground="{StaticResource TextSecondaryBrush}"
                                          VerticalAlignment="Center"
                                          Margin="8,0,0,0"/>
                            </Grid>
                            
                            <!-- Widget transparency sliders (generated dynamically from WidgetRegistry) -->
                            <StackPanel x:Name="TransparencySlidersContainer"/>
                        </StackPanel>
                    </Border>

                    <!-- Living Widgets snap spacing -->
                    <Border Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Widget Snap Gap"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Controls spacing between widgets when snapping and auto-attaching in Living Widgets Mode."
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Tight"
                                           FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>

                                <Slider x:Name="WidgetSnapGapSlider"
                                       Grid.Column="1"
                                       Minimum="4"
                                       Maximum="64"
                                       TickFrequency="2"
                                       IsSnapToTickEnabled="True"
                                       Value="12"
                                       ValueChanged="WidgetSnapGapSlider_ValueChanged"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource StyledSlider}"/>

                                <TextBlock x:Name="WidgetSnapGapValueText"
                                           Grid.Column="2"
                                           Text="12 px"
                                           FontSize="11"
                                           FontWeight="Medium"
                                           Foreground="{StaticResource TextBrush}"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Widget Overlap Prevention toggle -->
                    <Border Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,12,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Widget Overlap Prevention"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="When enabled, widgets cannot overlap each other and will snap back if dropped on another widget. When disabled, widgets can be freely placed anywhere, even overlapping."
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <ToggleButton x:Name="WidgetOverlapPreventionToggle" Style="{StaticResource ToggleSwitch}"
                                          Grid.Column="1"
                                          Width="50"
                                          Height="28"
                                          VerticalAlignment="Center"
                                          Checked="WidgetOverlapPreventionToggle_Changed"
                                          Unchecked="WidgetOverlapPreventionToggle_Changed"
                                          Cursor="Hand">
                            </ToggleButton>
                        </Grid>
                    </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                    
                    <!-- General Panel -->
                    <Border x:Name="GeneralPanel" Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="20" Visibility="Visible">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource ThinScrollViewer}">
                            <StackPanel>
                    
                    <!-- Auto-start Section -->
                    <Border Background="#18FFFFFF" 
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Run at Startup" 
                                           FontSize="16" 
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Launch DesktopHub automatically when Windows starts" 
                                           FontSize="12" 
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            
                            <ToggleButton x:Name="AutoStartToggle" Style="{StaticResource ToggleSwitch}"
                                          Grid.Column="1"
                                          Width="50"
                                          Height="28"
                                          VerticalAlignment="Center"
                                          Checked="AutoStartToggle_Checked"
                                          Unchecked="AutoStartToggle_Unchecked"
                                          Cursor="Hand">
                            </ToggleButton>
                        </Grid>
                    </Border>
                    
                    <!-- Path Search Section -->
                    <Border Background="#18FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Path Search" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="When enabled, typing a valid directory path into the search bar will list its contents" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                            
                            <!-- Enable Path Search -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Enable Path Search" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                                    <TextBlock Text="Browse directories by entering a path in the search field" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleButton x:Name="PathSearchEnabledToggle" Style="{StaticResource ToggleSwitch}" Grid.Column="1" Width="50" Height="28" VerticalAlignment="Center" IsChecked="False"
                                              Checked="PathSearchToggle_Changed" Unchecked="PathSearchToggle_Changed" Cursor="Hand">
                                </ToggleButton>
                            </Grid>
                            
                            <!-- Show Sub-Directories -->
                            <Grid Margin="16,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Show sub-directories" FontSize="13" Foreground="{StaticResource TextBrush}"/>
                                <ToggleButton x:Name="PathSearchSubDirsToggle" Style="{StaticResource ToggleSwitch}" Grid.Column="1" Width="50" Height="28" VerticalAlignment="Center" IsChecked="True"
                                              Checked="PathSearchToggle_Changed" Unchecked="PathSearchToggle_Changed" Cursor="Hand">
                                </ToggleButton>
                            </Grid>
                            
                            <!-- Show Sub-Files -->
                            <Grid Margin="16,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Show sub-files" FontSize="13" Foreground="{StaticResource TextBrush}"/>
                                <ToggleButton x:Name="PathSearchSubFilesToggle" Style="{StaticResource ToggleSwitch}" Grid.Column="1" Width="50" Height="28" VerticalAlignment="Center" IsChecked="True"
                                              Checked="PathSearchToggle_Changed" Unchecked="PathSearchToggle_Changed" Cursor="Hand">
                                </ToggleButton>
                            </Grid>
                            
                            <!-- Show Hidden Files -->
                            <Grid Margin="16,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Show hidden/system files" FontSize="13" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                                    <TextBlock Text="Include files like Thumbs.db, desktop.ini, etc." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleButton x:Name="PathSearchShowHiddenToggle" Style="{StaticResource ToggleSwitch}" Grid.Column="1" Width="50" Height="28" VerticalAlignment="Center" IsChecked="False"
                                              Checked="PathSearchToggle_Changed" Unchecked="PathSearchToggle_Changed" Cursor="Hand">
                                </ToggleButton>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- Network Drives Section -->
                    <Border Background="{StaticResource SurfaceBrush}" 
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Network Drives" 
                                       FontSize="16" 
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,0,8"/>
                            
                            <TextBlock Text="Configure which network drives to scan for projects" 
                                       FontSize="12" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,16"/>
                            
                            <!-- Q Drive -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <ToggleButton x:Name="QDriveEnabledToggle" Style="{StaticResource ToggleSwitch}"
                                              Grid.Column="0"
                                              Width="50"
                                              Height="28"
                                              VerticalAlignment="Bottom"
                                              Margin="0,0,12,4"
                                              Checked="QDriveEnabledToggle_Checked"
                                              Unchecked="QDriveEnabledToggle_Unchecked"
                                              Cursor="Hand">
                                </ToggleButton>
                                
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Q: Drive (Florida)" 
                                               FontSize="14" 
                                               FontWeight="Medium"
                                               Foreground="{StaticResource TextBrush}"
                                               Margin="0,0,0,4"/>
                                    <TextBox x:Name="QDrivePathBox"
                                             Text="Q:\"
                                             FontSize="12"
                                             Padding="6"
                                             Background="#22FFFFFF"
                                             Foreground="{StaticResource TextBrush}"
                                             BorderBrush="{StaticResource BorderBrush}"
                                             TextChanged="QDrivePathBox_TextChanged">
                                        <TextBox.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="4"/>
                                            </Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                </StackPanel>
                            </Grid>
                            
                            <!-- P Drive -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <ToggleButton x:Name="PDriveEnabledToggle" Style="{StaticResource ToggleSwitch}"
                                              Grid.Column="0"
                                              Width="50"
                                              Height="28"
                                              VerticalAlignment="Bottom"
                                              Margin="0,0,12,4"
                                              Checked="PDriveEnabledToggle_Checked"
                                              Unchecked="PDriveEnabledToggle_Unchecked"
                                              Cursor="Hand">
                                </ToggleButton>
                                
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="P: Drive (Connecticut)" 
                                               FontSize="14" 
                                               FontWeight="Medium"
                                               Foreground="{StaticResource TextBrush}"
                                               Margin="0,0,0,4"/>
                                    <TextBox x:Name="PDrivePathBox"
                                             Text="P:\"
                                             FontSize="12"
                                             Padding="6"
                                             Background="#22FFFFFF"
                                             Foreground="{StaticResource TextBrush}"
                                             BorderBrush="{StaticResource BorderBrush}"
                                             TextChanged="PDrivePathBox_TextChanged">
                                        <TextBox.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="4"/>
                                            </Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <!-- Living Widgets Mode Section -->
                    <Border Background="{StaticResource SurfaceBrush}" 
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Living Widgets Mode" 
                                           FontSize="16" 
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock FontSize="12" 
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap">
                                    <Run Text="Make widgets draggable, snappable to screen edges, and pinnable to desktop."/>
                                    <LineBreak/>
                                    <Run Text="When enabled, widgets stay visible until manually closed with hotkey."/>
                                    <LineBreak/>
                                    <Run Text="When disabled (default), widgets auto-hide when clicking away."/>
