                            <TextBlock Text="Categories" 
                                       FontSize="16" 
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Right-click a task to assign a category" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                            
                            <StackPanel x:Name="QT_CategoriesList" Margin="0,0,0,8"/>
                            
                            <!-- Add Category -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="QT_NewCategoryInput" Grid.Column="0" FontSize="12" Padding="6" 
                                         Background="#22FFFFFF" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}"
                                         KeyDown="QT_NewCategoryInput_KeyDown">
                                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></TextBox.Resources>
                                </TextBox>
                                <Button Grid.Column="1" Content="+ Add" Padding="10,6" Margin="8,0,0,0"
                                        Background="#22FFFFFF" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}"
                                        Click="QT_AddCategory_Click" Cursor="Hand">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                    
                    <!-- Doc Quick Open Panel -->
                    <Border x:Name="DocQuickOpenPanel" Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="20" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource ThinScrollViewer}">
                            <StackPanel>
                    
                    <!-- Display Settings -->
                    <Border Background="#18FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
