<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         THEME BRUSHES
         SolidColorBrush resources that bind to Color keys from
         DarkColors.xaml / LightColors.xaml via DynamicResource.
         When the color dictionary is swapped at runtime, these brushes
         auto-update — so even StaticResource references to brushes work.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ── Window / Chrome ── -->
    <SolidColorBrush x:Key="WindowBackgroundBrush"      Color="{DynamicResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="WindowBackgroundAlphaBrush"  Color="{DynamicResource WindowBackgroundAlphaColor}"/>
    <SolidColorBrush x:Key="WindowBackgroundDeepBrush"   Color="{DynamicResource WindowBackgroundDeepColor}"/>
    <SolidColorBrush x:Key="WindowBorderBrush"           Color="{DynamicResource WindowBorderColor}"/>
    <SolidColorBrush x:Key="WindowBorderSolidBrush"      Color="{DynamicResource WindowBorderSolidColor}"/>
    <SolidColorBrush x:Key="GlassBorderBrush"            Color="{DynamicResource GlassBorderColor}"/>
    <SolidColorBrush x:Key="GlassBackgroundBrush"        Color="{DynamicResource GlassBackgroundColor}"/>

    <!-- ── Surfaces ── -->
    <SolidColorBrush x:Key="SurfaceBrush"                Color="{DynamicResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceSolidBrush"           Color="{DynamicResource SurfaceSolidColor}"/>
    <SolidColorBrush x:Key="CardBrush"                   Color="{DynamicResource CardColor}"/>
    <SolidColorBrush x:Key="CardBorderBrush"             Color="{DynamicResource CardBorderColor}"/>
    <SolidColorBrush x:Key="InputBackgroundBrush"        Color="{DynamicResource InputBackgroundColor}"/>
    <SolidColorBrush x:Key="InputBackgroundAltBrush"     Color="{DynamicResource InputBackgroundAltColor}"/>
    <SolidColorBrush x:Key="PopupBackgroundBrush"        Color="{DynamicResource PopupBackgroundColor}"/>

    <!-- ── Text ── -->
    <SolidColorBrush x:Key="TextPrimaryBrush"            Color="{DynamicResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"          Color="{DynamicResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush"           Color="{DynamicResource TextTertiaryColor}"/>
    <SolidColorBrush x:Key="TextOnAccentBrush"           Color="{DynamicResource TextOnAccentColor}"/>
    <SolidColorBrush x:Key="TextPlaceholderBrush"        Color="{DynamicResource TextPlaceholderColor}"/>

    <!-- ── Accent ── -->
    <SolidColorBrush x:Key="AccentBrush"                 Color="{DynamicResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush"            Color="{DynamicResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentLightBrush"            Color="{DynamicResource AccentLightColor}"/>

    <!-- ── Interactive ── -->
    <SolidColorBrush x:Key="HoverBrush"                  Color="{DynamicResource HoverColor}"/>
    <SolidColorBrush x:Key="HoverMediumBrush"            Color="{DynamicResource HoverMediumColor}"/>
    <SolidColorBrush x:Key="HoverStrongBrush"            Color="{DynamicResource HoverStrongColor}"/>
    <SolidColorBrush x:Key="SelectedBrush"               Color="{DynamicResource SelectedColor}"/>
    <SolidColorBrush x:Key="SelectedAccentBrush"         Color="{DynamicResource SelectedAccentColor}"/>
    <SolidColorBrush x:Key="PressedBrush"                Color="{DynamicResource PressedColor}"/>

    <!-- ── Borders ── -->
    <SolidColorBrush x:Key="BorderBrush"                 Color="{DynamicResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush"           Color="{DynamicResource BorderSubtleColor}"/>

    <!-- ── Controls ── -->
    <SolidColorBrush x:Key="ToggleOffBrush"              Color="{DynamicResource ToggleOffColor}"/>
    <SolidColorBrush x:Key="ToggleOnBrush"               Color="{DynamicResource ToggleOnColor}"/>
    <SolidColorBrush x:Key="ToggleThumbBrush"            Color="{DynamicResource ToggleThumbColor}"/>
    <SolidColorBrush x:Key="ScrollbarThumbBrush"         Color="{DynamicResource ScrollbarThumbColor}"/>
    <SolidColorBrush x:Key="ScrollbarThumbAltBrush"      Color="{DynamicResource ScrollbarThumbAltColor}"/>
    <SolidColorBrush x:Key="SliderTrackBrush"            Color="{DynamicResource SliderTrackColor}"/>

    <!-- ── Semantic: Gold / Favorite ── -->
    <SolidColorBrush x:Key="GoldBrush"                   Color="{DynamicResource GoldColor}"/>
    <SolidColorBrush x:Key="GoldDarkBrush"               Color="{DynamicResource GoldDarkColor}"/>
    <SolidColorBrush x:Key="GoldBackgroundBrush"         Color="{DynamicResource GoldBackgroundColor}"/>

    <!-- ── Semantic: Orange / Warning ── -->
    <SolidColorBrush x:Key="OrangeBrush"                 Color="{DynamicResource OrangeColor}"/>
    <SolidColorBrush x:Key="OrangeBackgroundBrush"       Color="{DynamicResource OrangeBackgroundColor}"/>

    <!-- ── Semantic: Red / Error ── -->
    <SolidColorBrush x:Key="RedBrush"                    Color="{DynamicResource RedColor}"/>
    <SolidColorBrush x:Key="RedBackgroundBrush"          Color="{DynamicResource RedBackgroundColor}"/>

    <!-- ── Semantic: Green / Success ── -->
    <SolidColorBrush x:Key="GreenBrush"                  Color="{DynamicResource GreenColor}"/>
    <SolidColorBrush x:Key="GreenBackgroundBrush"        Color="{DynamicResource GreenBackgroundColor}"/>

    <!-- ── Semantic: Blue / Info ── -->
    <SolidColorBrush x:Key="BlueBrush"                   Color="{DynamicResource BlueColor}"/>
    <SolidColorBrush x:Key="BlueBackgroundBrush"         Color="{DynamicResource BlueBackgroundColor}"/>
    <SolidColorBrush x:Key="BlueBorderBrush"             Color="{DynamicResource BlueBorderColor}"/>
    <SolidColorBrush x:Key="BlueTextBrush"               Color="{DynamicResource BlueTextColor}"/>

    <!-- ── Semantic: Purple / Metrics ── -->
    <SolidColorBrush x:Key="PurpleBrush"                 Color="{DynamicResource PurpleColor}"/>
    <SolidColorBrush x:Key="PurpleBackgroundBrush"       Color="{DynamicResource PurpleBackgroundColor}"/>

    <!-- ── Warning Banner ── -->
    <SolidColorBrush x:Key="WarningBannerBackgroundBrush" Color="{DynamicResource WarningBannerBackgroundColor}"/>
    <SolidColorBrush x:Key="WarningBannerBorderBrush"     Color="{DynamicResource WarningBannerBorderColor}"/>
    <SolidColorBrush x:Key="WarningBannerTextBrush"       Color="{DynamicResource WarningBannerTextColor}"/>

    <!-- ── Subtle Overlay Tints ── -->
    <SolidColorBrush x:Key="SubtleOverlayBrush"          Color="{DynamicResource SubtleOverlayColor}"/>
    <SolidColorBrush x:Key="MediumOverlayBrush"          Color="{DynamicResource MediumOverlayColor}"/>
    <SolidColorBrush x:Key="StrongOverlayBrush"          Color="{DynamicResource StrongOverlayColor}"/>
    <SolidColorBrush x:Key="FaintOverlayBrush"           Color="{DynamicResource FaintOverlayColor}"/>

    <!-- ── Miscellaneous ── -->
    <SolidColorBrush x:Key="DividerBrush"                Color="{DynamicResource DividerColor}"/>
    <SolidColorBrush x:Key="ShadowBrush"                 Color="{DynamicResource ShadowColor}"/>
    <SolidColorBrush x:Key="CopyIconForegroundBrush"     Color="{DynamicResource CopyIconForegroundColor}"/>

    <!-- ── Widget-Specific Semantic ── -->
    <SolidColorBrush x:Key="HighPriorityBrush"       Color="{DynamicResource HighPriorityColor}"/>
    <SolidColorBrush x:Key="NormalPriorityBrush"      Color="{DynamicResource NormalPriorityColor}"/>
    <SolidColorBrush x:Key="LowPriorityBrush"         Color="{DynamicResource LowPriorityColor}"/>
    <SolidColorBrush x:Key="RevitOrangeBrush"          Color="{DynamicResource RevitOrangeColor}"/>
    <SolidColorBrush x:Key="CadBlueBrush"              Color="{DynamicResource CadBlueColor}"/>
    <SolidColorBrush x:Key="CloudPurpleBrush"          Color="{DynamicResource CloudPurpleColor}"/>
    <SolidColorBrush x:Key="InputHighlightBrush"       Color="{DynamicResource InputHighlightColor}"/>
    <SolidColorBrush x:Key="OutputHighlightBrush"      Color="{DynamicResource OutputHighlightColor}"/>
    <SolidColorBrush x:Key="MatchHighlightBrush"       Color="{DynamicResource MatchHighlightColor}"/>

    <!-- ── Chart Palette ── -->
    <SolidColorBrush x:Key="ChartBlueBrush"            Color="{DynamicResource ChartBlueColor}"/>
    <SolidColorBrush x:Key="ChartGreenBrush"           Color="{DynamicResource ChartGreenColor}"/>
    <SolidColorBrush x:Key="ChartOrangeBrush"          Color="{DynamicResource ChartOrangeColor}"/>
    <SolidColorBrush x:Key="ChartPurpleBrush"          Color="{DynamicResource ChartPurpleColor}"/>
    <SolidColorBrush x:Key="ChartRedBrush"             Color="{DynamicResource ChartRedColor}"/>
    <SolidColorBrush x:Key="ChartCyanBrush"            Color="{DynamicResource ChartCyanColor}"/>
    <SolidColorBrush x:Key="ChartDeepOrangeBrush"      Color="{DynamicResource ChartDeepOrangeColor}"/>
    <SolidColorBrush x:Key="ChartLimeBrush"            Color="{DynamicResource ChartLimeColor}"/>
    <SolidColorBrush x:Key="ChartSlateBrush"           Color="{DynamicResource ChartSlateColor}"/>
    <SolidColorBrush x:Key="ChartIndigoBrush"          Color="{DynamicResource ChartIndigoColor}"/>
    <SolidColorBrush x:Key="ChartPinkBrush"            Color="{DynamicResource ChartPinkColor}"/>
    <SolidColorBrush x:Key="ChartSkyBlueBrush"         Color="{DynamicResource ChartSkyBlueColor}"/>
    <SolidColorBrush x:Key="ChartAmberBrush"           Color="{DynamicResource ChartAmberColor}"/>
    <SolidColorBrush x:Key="ChartBrownBrush"           Color="{DynamicResource ChartBrownColor}"/>
    <SolidColorBrush x:Key="ChartDeepPurpleBrush"      Color="{DynamicResource ChartDeepPurpleColor}"/>

    <!-- ══════════════════════════════════════════════════════════════
         BACKWARD-COMPATIBLE ALIASES
         The old ThemeColors.xaml defined these 8 keys.  We keep them
         so existing StaticResource references continue to compile.
         ══════════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="BackgroundBrush"  Color="{DynamicResource WindowBackgroundAlphaColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush"     Color="{DynamicResource AccentColor}"/>
    <SolidColorBrush x:Key="TextBrush"        Color="{DynamicResource TextPrimaryColor}"/>

</ResourceDictionary>
