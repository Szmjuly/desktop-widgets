<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Theme Colors - Semi-transparent without blur -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#401E1E1E"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#602D2D2D"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="#007ACC"/>
    <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#503A3A3A"/>
    <SolidColorBrush x:Key="SelectedBrush" Color="#80094771"/>

</ResourceDictionary>
