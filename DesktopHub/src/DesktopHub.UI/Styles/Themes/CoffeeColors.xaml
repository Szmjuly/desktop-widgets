<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         COFFEE THEME COLORS
         Warm, cozy palette inspired by coffee shop aesthetics.
         Rich browns, warm creams, caramel accents, espresso darks.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ── Window / Chrome ── -->
    <Color x:Key="WindowBackgroundColor">#3D2B1E</Color>
    <Color x:Key="WindowBackgroundAlphaColor">#E83D2B1E</Color>
    <Color x:Key="WindowBackgroundDeepColor">#E8362618</Color>
    <Color x:Key="WindowBorderColor">#5A4A3828</Color>
    <Color x:Key="WindowBorderSolidColor">#60604830</Color>
    <Color x:Key="GlassBorderColor">#30D4B896</Color>
    <Color x:Key="GlassBackgroundColor">#10000000</Color>

    <!-- ── Surfaces ── -->
    <Color x:Key="SurfaceColor">#60483828</Color>
    <Color x:Key="SurfaceSolidColor">#4A3828</Color>
    <Color x:Key="CardColor">#20D4B896</Color>
    <Color x:Key="CardBorderColor">#28D4B896</Color>
    <Color x:Key="InputBackgroundColor">#D8362618</Color>
    <Color x:Key="InputBackgroundAltColor">#28D4B896</Color>
    <Color x:Key="PopupBackgroundColor">#E8402E20</Color>

    <!-- ── Text ── -->
    <Color x:Key="TextPrimaryColor">#F0E6D8</Color>
    <Color x:Key="TextSecondaryColor">#BBA890</Color>
    <Color x:Key="TextTertiaryColor">#8A7A68</Color>
    <Color x:Key="TextOnAccentColor">#1A1008</Color>
    <Color x:Key="TextPlaceholderColor">#70907A64</Color>

    <!-- ── Accent (caramel/toffee) ── -->
    <Color x:Key="AccentColor">#D4943C</Color>
    <Color x:Key="AccentHoverColor">#C0842C</Color>
    <Color x:Key="AccentLightColor">#30D4943C</Color>

    <!-- ── Interactive ── -->
    <Color x:Key="HoverColor">#15D4B896</Color>
    <Color x:Key="HoverMediumColor">#20D4B896</Color>
    <Color x:Key="HoverStrongColor">#30D4B896</Color>
    <Color x:Key="SelectedColor">#28D4943C</Color>
    <Color x:Key="SelectedAccentColor">#40D4943C</Color>
    <Color x:Key="PressedColor">#38D4B896</Color>

    <!-- ── Borders ── -->
    <Color x:Key="BorderColor">#6A5A48</Color>
    <Color x:Key="BorderSubtleColor">#30D4B896</Color>

    <!-- ── Controls ── -->
    <Color x:Key="ToggleOffColor">#6A5A48</Color>
    <Color x:Key="ToggleOnColor">#D4943C</Color>
    <Color x:Key="ToggleThumbColor">#F0E6D8</Color>
    <Color x:Key="ScrollbarThumbColor">#50D4B896</Color>
    <Color x:Key="ScrollbarThumbAltColor">#40D4B896</Color>
    <Color x:Key="SliderTrackColor">#35D4B896</Color>

    <!-- ── Semantic: Gold / Favorite ── -->
    <Color x:Key="GoldColor">#E8B84C</Color>
    <Color x:Key="GoldDarkColor">#C89830</Color>
    <Color x:Key="GoldBackgroundColor">#30E8B84C</Color>

    <!-- ── Semantic: Orange / Warning ── -->
    <Color x:Key="OrangeColor">#E8863C</Color>
    <Color x:Key="OrangeBackgroundColor">#30E8863C</Color>

    <!-- ── Semantic: Red / Error ── -->
    <Color x:Key="RedColor">#D45050</Color>
    <Color x:Key="RedBackgroundColor">#30D45050</Color>

    <!-- ── Semantic: Green / Success ── -->
    <Color x:Key="GreenColor">#6AAF5C</Color>
    <Color x:Key="GreenBackgroundColor">#306AAF5C</Color>

    <!-- ── Semantic: Blue / Info ── -->
    <Color x:Key="BlueColor">#6A9FCA</Color>
    <Color x:Key="BlueBackgroundColor">#206A9FCA</Color>
    <Color x:Key="BlueBorderColor">#406A9FCA</Color>
    <Color x:Key="BlueTextColor">#8AB4D6</Color>

    <!-- ── Semantic: Purple / Metrics ── -->
    <Color x:Key="PurpleColor">#A878B8</Color>
    <Color x:Key="PurpleBackgroundColor">#30A878B8</Color>

    <!-- ── Warning Banner ── -->
    <Color x:Key="WarningBannerBackgroundColor">#302C1A00</Color>
    <Color x:Key="WarningBannerBorderColor">#60604020</Color>
    <Color x:Key="WarningBannerTextColor">#E8C890</Color>

    <!-- ── Subtle Overlay Tints ── -->
    <Color x:Key="SubtleOverlayColor">#12D4B896</Color>
    <Color x:Key="MediumOverlayColor">#20D4B896</Color>
    <Color x:Key="StrongOverlayColor">#30D4B896</Color>
    <Color x:Key="FaintOverlayColor">#08D4B896</Color>

    <!-- ── Widget-Specific Semantic ── -->
    <Color x:Key="HighPriorityColor">#D45050</Color>
    <Color x:Key="NormalPriorityColor">#BBA890</Color>
    <Color x:Key="LowPriorityColor">#8A7A68</Color>
    <Color x:Key="RevitOrangeColor">#E87838</Color>
    <Color x:Key="CadBlueColor">#6A9FCA</Color>
    <Color x:Key="CloudPurpleColor">#A878B8</Color>
    <Color x:Key="InputHighlightColor">#206A9FCA</Color>
    <Color x:Key="OutputHighlightColor">#206AAF5C</Color>
    <Color x:Key="MatchHighlightColor">#30E8B84C</Color>

    <!-- ── Chart Palette (warm-tinted) ── -->
    <Color x:Key="ChartBlueColor">#6A9FCA</Color>
    <Color x:Key="ChartGreenColor">#6AAF5C</Color>
    <Color x:Key="ChartOrangeColor">#E8A044</Color>
    <Color x:Key="ChartPurpleColor">#A878B8</Color>
    <Color x:Key="ChartLightBlueColor">#78B0D8</Color>
    <Color x:Key="ChartRedColor">#D45050</Color>
    <Color x:Key="ChartCyanColor">#58B8B0</Color>
    <Color x:Key="ChartDeepOrangeColor">#D87040</Color>
    <Color x:Key="ChartLimeColor">#90B858</Color>
    <Color x:Key="ChartSlateColor">#8A8070</Color>
    <Color x:Key="ChartIndigoColor">#7080B0</Color>
    <Color x:Key="ChartPinkColor">#C87090</Color>
    <Color x:Key="ChartSkyBlueColor">#68A8D0</Color>
    <Color x:Key="ChartAmberColor">#E8C040</Color>
    <Color x:Key="ChartBrownColor">#8A6848</Color>
    <Color x:Key="ChartDeepPurpleColor">#8868A8</Color>

    <!-- ── Miscellaneous ── -->
    <Color x:Key="DividerColor">#20D4B896</Color>
    <Color x:Key="ShadowColor">#40000000</Color>
    <Color x:Key="TransparentColor">#00000000</Color>
    <Color x:Key="CopyIconForegroundColor">#F0E6D8</Color>

</ResourceDictionary>
