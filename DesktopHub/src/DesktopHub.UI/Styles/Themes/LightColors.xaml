<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         LIGHT THEME COLORS
         Proper light mode: white/near-white backgrounds, dark text,
         solid opaque chromes, high contrast.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ── Window / Chrome ── -->
    <Color x:Key="WindowBackgroundColor">#FFFFFF</Color>
    <Color x:Key="WindowBackgroundAlphaColor">#F5F7FA</Color>
    <Color x:Key="WindowBackgroundDeepColor">#F0F2F5</Color>
    <Color x:Key="WindowBorderColor">#D1D5DB</Color>
    <Color x:Key="WindowBorderSolidColor">#C8CCD2</Color>
    <Color x:Key="GlassBorderColor">#E0E4E8</Color>
    <Color x:Key="GlassBackgroundColor">#08000000</Color>

    <!-- ── Surfaces ── -->
    <Color x:Key="SurfaceColor">#F0F2F5</Color>
    <Color x:Key="SurfaceSolidColor">#FFFFFF</Color>
    <Color x:Key="CardColor">#FFFFFF</Color>
    <Color x:Key="CardBorderColor">#E2E6EA</Color>
    <Color x:Key="InputBackgroundColor">#FFFFFF</Color>
    <Color x:Key="InputBackgroundAltColor">#F5F7FA</Color>
    <Color x:Key="PopupBackgroundColor">#FFFFFF</Color>

    <!-- ── Text ── -->
    <Color x:Key="TextPrimaryColor">#1A1A2E</Color>
    <Color x:Key="TextSecondaryColor">#5F6B7A</Color>
    <Color x:Key="TextTertiaryColor">#8896A6</Color>
    <Color x:Key="TextOnAccentColor">#FFFFFF</Color>
    <Color x:Key="TextPlaceholderColor">#A0ADB8</Color>

    <!-- ── Accent ── -->
    <Color x:Key="AccentColor">#0078D4</Color>
    <Color x:Key="AccentHoverColor">#005EA6</Color>
    <Color x:Key="AccentLightColor">#E6F2FC</Color>

    <!-- ── Interactive ── -->
    <Color x:Key="HoverColor">#F0F2F5</Color>
    <Color x:Key="HoverMediumColor">#E8EBF0</Color>
    <Color x:Key="HoverStrongColor">#DDE1E8</Color>
    <Color x:Key="SelectedColor">#E0E7F0</Color>
    <Color x:Key="SelectedAccentColor">#CCE4F7</Color>
    <Color x:Key="PressedColor">#D0D5DD</Color>

    <!-- ── Borders ── -->
    <Color x:Key="BorderColor">#D1D5DB</Color>
    <Color x:Key="BorderSubtleColor">#E8ECF0</Color>

    <!-- ── Controls ── -->
    <Color x:Key="ToggleOffColor">#C8CCD2</Color>
    <Color x:Key="ToggleOnColor">#0078D4</Color>
    <Color x:Key="ToggleThumbColor">#FFFFFF</Color>
    <Color x:Key="ScrollbarThumbColor">#B0B8C4</Color>
    <Color x:Key="ScrollbarThumbAltColor">#C0C8D0</Color>
    <Color x:Key="SliderTrackColor">#D0D5DD</Color>

    <!-- ── Semantic: Gold / Favorite ── -->
    <Color x:Key="GoldColor">#D4930D</Color>
    <Color x:Key="GoldDarkColor">#A87008</Color>
    <Color x:Key="GoldBackgroundColor">#FFF8E1</Color>

    <!-- ── Semantic: Orange / Warning ── -->
    <Color x:Key="OrangeColor">#E67E00</Color>
    <Color x:Key="OrangeBackgroundColor">#FFF3E0</Color>

    <!-- ── Semantic: Red / Error ── -->
    <Color x:Key="RedColor">#D32F2F</Color>
    <Color x:Key="RedBackgroundColor">#FFEBEE</Color>

    <!-- ── Semantic: Green / Success ── -->
    <Color x:Key="GreenColor">#2E7D32</Color>
    <Color x:Key="GreenBackgroundColor">#E8F5E9</Color>

    <!-- ── Semantic: Blue / Info ── -->
    <Color x:Key="BlueColor">#1565C0</Color>
    <Color x:Key="BlueBackgroundColor">#E3F2FD</Color>
    <Color x:Key="BlueBorderColor">#90CAF9</Color>
    <Color x:Key="BlueTextColor">#1565C0</Color>

    <!-- ── Semantic: Purple / Metrics ── -->
    <Color x:Key="PurpleColor">#6A1B9A</Color>
    <Color x:Key="PurpleBackgroundColor">#F3E5F5</Color>

    <!-- ── Warning Banner ── -->
    <Color x:Key="WarningBannerBackgroundColor">#FFF8E1</Color>
    <Color x:Key="WarningBannerBorderColor">#FFE082</Color>
    <Color x:Key="WarningBannerTextColor">#7B6100</Color>

    <!-- ── Subtle Overlay Tints ── -->
    <Color x:Key="SubtleOverlayColor">#F5F7FA</Color>
    <Color x:Key="MediumOverlayColor">#EEF1F5</Color>
    <Color x:Key="StrongOverlayColor">#E5E9EF</Color>
    <Color x:Key="FaintOverlayColor">#F8FAFB</Color>

    <!-- ── Widget-Specific Semantic ── -->
    <Color x:Key="HighPriorityColor">#D32F2F</Color>
    <Color x:Key="NormalPriorityColor">#78909C</Color>
    <Color x:Key="LowPriorityColor">#90A4AE</Color>
    <Color x:Key="RevitOrangeColor">#E65100</Color>
    <Color x:Key="CadBlueColor">#0277BD</Color>
    <Color x:Key="CloudPurpleColor">#7B1FA2</Color>
    <Color x:Key="InputHighlightColor">#E3F2FD</Color>
    <Color x:Key="OutputHighlightColor">#E8F5E9</Color>
    <Color x:Key="MatchHighlightColor">#FFF8E1</Color>

    <!-- ── Chart Palette ── -->
    <Color x:Key="ChartBlueColor">#1565C0</Color>
    <Color x:Key="ChartGreenColor">#2E7D32</Color>
    <Color x:Key="ChartOrangeColor">#EF6C00</Color>
    <Color x:Key="ChartPurpleColor">#7B1FA2</Color>
    <Color x:Key="ChartLightBlueColor">#0277BD</Color>
    <Color x:Key="ChartRedColor">#C62828</Color>
    <Color x:Key="ChartCyanColor">#00838F</Color>
    <Color x:Key="ChartDeepOrangeColor">#D84315</Color>
    <Color x:Key="ChartLimeColor">#558B2F</Color>
    <Color x:Key="ChartSlateColor">#455A64</Color>
    <Color x:Key="ChartIndigoColor">#283593</Color>
    <Color x:Key="ChartPinkColor">#AD1457</Color>
    <Color x:Key="ChartSkyBlueColor">#0277BD</Color>
    <Color x:Key="ChartAmberColor">#FF8F00</Color>
    <Color x:Key="ChartBrownColor">#4E342E</Color>
    <Color x:Key="ChartDeepPurpleColor">#4527A0</Color>

    <!-- ── Miscellaneous ── -->
    <Color x:Key="DividerColor">#E2E6EA</Color>
    <Color x:Key="ShadowColor">#18000000</Color>
    <Color x:Key="TransparentColor">#00000000</Color>
    <Color x:Key="CopyIconForegroundColor">#5F6B7A</Color>

</ResourceDictionary>
