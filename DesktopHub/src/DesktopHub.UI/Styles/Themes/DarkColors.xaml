<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         DARK THEME COLORS
         All Color resources used by ThemeBrushes.xaml via DynamicResource.
         LightColors.xaml defines the same keys with light-mode values.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ── Window / Chrome ── -->
    <Color x:Key="WindowBackgroundColor">#121212</Color>
    <Color x:Key="WindowBackgroundAlphaColor">#A8121212</Color>
    <Color x:Key="WindowBackgroundDeepColor">#C8181818</Color>
    <Color x:Key="WindowBorderColor">#3A2A2A2A</Color>
    <Color x:Key="WindowBorderSolidColor">#442A2A2A</Color>
    <Color x:Key="GlassBorderColor">#33FFFFFF</Color>
    <Color x:Key="GlassBackgroundColor">#14000000</Color>

    <!-- ── Surfaces ── -->
    <Color x:Key="SurfaceColor">#602D2D2D</Color>
    <Color x:Key="SurfaceSolidColor">#2D2D2D</Color>
    <Color x:Key="CardColor">#18FFFFFF</Color>
    <Color x:Key="CardBorderColor">#22FFFFFF</Color>
    <Color x:Key="InputBackgroundColor">#D0121212</Color>
    <Color x:Key="InputBackgroundAltColor">#22FFFFFF</Color>
    <Color x:Key="PopupBackgroundColor">#D0121212</Color>

    <!-- ── Text ── -->
    <Color x:Key="TextPrimaryColor">#F5F7FA</Color>
    <Color x:Key="TextSecondaryColor">#AAAAAA</Color>
    <Color x:Key="TextTertiaryColor">#777777</Color>
    <Color x:Key="TextOnAccentColor">#FFFFFF</Color>
    <Color x:Key="TextPlaceholderColor">#88AAAAAA</Color>

    <!-- ── Accent ── -->
    <Color x:Key="AccentColor">#007ACC</Color>
    <Color x:Key="AccentHoverColor">#1A8AD6</Color>
    <Color x:Key="AccentLightColor">#30007ACC</Color>

    <!-- ── Interactive ── -->
    <Color x:Key="HoverColor">#15F5F7FA</Color>
    <Color x:Key="HoverMediumColor">#20F5F7FA</Color>
    <Color x:Key="HoverStrongColor">#33FFFFFF</Color>
    <Color x:Key="SelectedColor">#30F5F7FA</Color>
    <Color x:Key="SelectedAccentColor">#80094771</Color>
    <Color x:Key="PressedColor">#40F5F7FA</Color>

    <!-- ── Borders ── -->
    <Color x:Key="BorderColor">#3F3F46</Color>
    <Color x:Key="BorderSubtleColor">#22FFFFFF</Color>

    <!-- ── Controls ── -->
    <Color x:Key="ToggleOffColor">#505050</Color>
    <Color x:Key="ToggleOnColor">#007ACC</Color>
    <Color x:Key="ToggleThumbColor">#FFFFFF</Color>
    <Color x:Key="ScrollbarThumbColor">#60F5F7FA</Color>
    <Color x:Key="ScrollbarThumbAltColor">#40FFFFFF</Color>
    <Color x:Key="SliderTrackColor">#40FFFFFF</Color>

    <!-- ── Semantic: Gold / Favorite ── -->
    <Color x:Key="GoldColor">#FFD700</Color>
    <Color x:Key="GoldDarkColor">#DAA520</Color>
    <Color x:Key="GoldBackgroundColor">#33DAA520</Color>

    <!-- ── Semantic: Orange / Warning ── -->
    <Color x:Key="OrangeColor">#FF8C00</Color>
    <Color x:Key="OrangeBackgroundColor">#33FF8C00</Color>

    <!-- ── Semantic: Red / Error ── -->
    <Color x:Key="RedColor">#FF4444</Color>
    <Color x:Key="RedBackgroundColor">#33FF4444</Color>

    <!-- ── Semantic: Green / Success ── -->
    <Color x:Key="GreenColor">#2ECC71</Color>
    <Color x:Key="GreenBackgroundColor">#332ECC71</Color>

    <!-- ── Semantic: Blue / Info ── -->
    <Color x:Key="BlueColor">#649BF0</Color>
    <Color x:Key="BlueBackgroundColor">#20649BF0</Color>
    <Color x:Key="BlueBorderColor">#40649BF0</Color>
    <Color x:Key="BlueTextColor">#A0B8D8</Color>

    <!-- ── Semantic: Purple / Metrics ── -->
    <Color x:Key="PurpleColor">#B39DDB</Color>
    <Color x:Key="PurpleBackgroundColor">#33B39DDB</Color>

    <!-- ── Warning Banner ── -->
    <Color x:Key="WarningBannerBackgroundColor">#332B1B00</Color>
    <Color x:Key="WarningBannerBorderColor">#665A3A00</Color>
    <Color x:Key="WarningBannerTextColor">#F3D6A2</Color>

    <!-- ── Subtle Overlay Tints ── -->
    <Color x:Key="SubtleOverlayColor">#15FFFFFF</Color>
    <Color x:Key="MediumOverlayColor">#25FFFFFF</Color>
    <Color x:Key="StrongOverlayColor">#35FFFFFF</Color>
    <Color x:Key="FaintOverlayColor">#08FFFFFF</Color>

    <!-- ── Widget-Specific Semantic ── -->
    <Color x:Key="HighPriorityColor">#FF5252</Color>
    <Color x:Key="NormalPriorityColor">#B0BEC5</Color>
    <Color x:Key="LowPriorityColor">#546E7A</Color>
    <Color x:Key="RevitOrangeColor">#FF6B35</Color>
    <Color x:Key="CadBlueColor">#4FC3F7</Color>
    <Color x:Key="CloudPurpleColor">#AB47BC</Color>
    <Color x:Key="InputHighlightColor">#304FC3F7</Color>
    <Color x:Key="OutputHighlightColor">#3066BB6A</Color>
    <Color x:Key="MatchHighlightColor">#30FFD54F</Color>

    <!-- ── Chart Palette ── -->
    <Color x:Key="ChartBlueColor">#42A5F5</Color>
    <Color x:Key="ChartGreenColor">#66BB6A</Color>
    <Color x:Key="ChartOrangeColor">#FFA726</Color>
    <Color x:Key="ChartPurpleColor">#AB47BC</Color>
    <Color x:Key="ChartLightBlueColor">#42A5F5</Color>
    <Color x:Key="ChartRedColor">#EF5350</Color>
    <Color x:Key="ChartCyanColor">#26C6DA</Color>
    <Color x:Key="ChartDeepOrangeColor">#FF7043</Color>
    <Color x:Key="ChartLimeColor">#9CCC65</Color>
    <Color x:Key="ChartSlateColor">#78909C</Color>
    <Color x:Key="ChartIndigoColor">#5C6BC0</Color>
    <Color x:Key="ChartPinkColor">#EC407A</Color>
    <Color x:Key="ChartSkyBlueColor">#29B6F6</Color>
    <Color x:Key="ChartAmberColor">#FFCA28</Color>
    <Color x:Key="ChartBrownColor">#8D6E63</Color>
    <Color x:Key="ChartDeepPurpleColor">#7E57C2</Color>

    <!-- ── Miscellaneous ── -->
    <Color x:Key="DividerColor">#20FFFFFF</Color>
    <Color x:Key="ShadowColor">#40000000</Color>
    <Color x:Key="TransparentColor">#00000000</Color>
    <Color x:Key="CopyIconForegroundColor">#FFFFFF</Color>

</ResourceDictionary>
