<Window x:Class="DesktopHub.UI.HotkeyConflictDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopHub"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Width="480"
        Height="320"
        Topmost="True"
        ShowInTaskbar="False">

    <Border x:Name="RootBorder"
            Background="{DynamicResource WindowBackgroundDeepBrush}"
            CornerRadius="12"
            BorderBrush="{DynamicResource WindowBorderSolidBrush}"
            BorderThickness="1">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0"
                       x:Name="TitleText"
                       Text="Shortcut In Use"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,10"/>

            <!-- Subtitle -->
            <TextBlock Grid.Row="1"
                       x:Name="SubtitleText"
                       Text="Another application has already registered this shortcut."
                       TextWrapping="Wrap"
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,14"/>

            <!-- Hotkey card -->
            <Border Grid.Row="2"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,14,16,14"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Conflicting shortcut"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,6"/>
                    <TextBlock x:Name="HotkeyText"
                               Text="Ctrl+Alt+Space"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Hint -->
            <TextBlock Grid.Row="3"
                       x:Name="HintText"
                       Text="Windows only allows one app to own a shortcut at a time. Common culprits: Claude Desktop, PowerToys, Copilot, or other launchers. Pick a different combo, or close the conflicting app first."
                       TextWrapping="Wrap"
                       FontSize="12"
                       LineHeight="18"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,16"/>

            <!-- Buttons -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        x:Name="OpenConflictingAppButton"
                        Content="Open Claude Desktop"
                        MinWidth="100"
                        Padding="12,0,12,0"
                        Height="32"
                        Margin="0,0,8,0"
                        Visibility="Collapsed"
                        Background="{DynamicResource CardBorderBrush}"
                        Foreground="{DynamicResource TextBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        Click="OpenConflictingAppButton_Click"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource HoverStrongBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="2"
                        x:Name="SecondaryButton"
                        Content="Dismiss"
                        Width="100"
                        Height="32"
                        Margin="0,0,8,0"
                        Background="{DynamicResource CardBorderBrush}"
                        Foreground="{DynamicResource TextBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        Click="SecondaryButton_Click"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource HoverStrongBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="3"
                        x:Name="PrimaryButton"
                        Content="OK"
                        Width="120"
                        Height="32"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="White"
                        BorderBrush="{DynamicResource PrimaryBrush}"
                        Click="PrimaryButton_Click"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
