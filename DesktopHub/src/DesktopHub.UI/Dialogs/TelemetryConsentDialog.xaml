<Window x:Class="DesktopHub.UI.TelemetryConsentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopHub"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Width="520"
        SizeToContent="Height"
        Topmost="True"
        ShowInTaskbar="False">

    <Border x:Name="RootBorder"
            Background="{DynamicResource WindowBackgroundDeepBrush}"
            CornerRadius="12"
            BorderBrush="{DynamicResource WindowBorderSolidBrush}"
            BorderThickness="1">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                <Border Width="36" Height="36" CornerRadius="18"
                        Background="{DynamicResource BlueBackgroundBrush}"
                        VerticalAlignment="Center">
                    <TextBlock Text="&#x1F6E1;"
                               FontSize="18"
                               Foreground="{DynamicResource BlueBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Help improve DesktopHub"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"
                           Margin="14,0,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Intro -->
            <TextBlock Grid.Row="1"
                       Text="DesktopHub can send anonymous usage data to help us find bugs and prioritize features. Your choice is remembered and you can change it anytime in Settings &#x2192; Privacy."
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,18"/>

            <!-- What is / isn't collected -->
            <Border Grid.Row="2"
                    Background="{DynamicResource FaintOverlayBrush}"
                    CornerRadius="8"
                    Padding="16,12"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="When enabled, we collect:"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,6"/>
                    <TextBlock FontSize="12"
                               Foreground="{DynamicResource TextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,4">
                        &#x2022; Feature usage counts (searches, hotkey presses, widget opens)
                    </TextBlock>
                    <TextBlock FontSize="12"
                               Foreground="{DynamicResource TextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,4">
                        &#x2022; Anonymized performance timings and error stack traces
                    </TextBlock>
                    <TextBlock FontSize="12"
                               Foreground="{DynamicResource TextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10">
                        &#x2022; App version, OS version, hashed hardware identifier
                    </TextBlock>

                    <TextBlock Text="We never collect:"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,6"/>
                    <TextBlock FontSize="12"
                               Foreground="{DynamicResource TextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,4">
                        &#x2022; The contents of your searches, files, or documents
                    </TextBlock>
                    <TextBlock FontSize="12"
                               Foreground="{DynamicResource TextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,4">
                        &#x2022; Keystrokes, clipboard contents, or screen contents
                    </TextBlock>
                    <TextBlock FontSize="12"
                               Foreground="{DynamicResource TextBrush}"
                               TextWrapping="Wrap">
                        &#x2022; Your raw MAC address, IP, or any identifiable personal data
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Footnote -->
            <TextBlock Grid.Row="3"
                       Text="Heartbeat, license validation, and update checks remain on regardless -- these are required for the app to work at all."
                       FontSize="11"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,18"/>

            <!-- Buttons -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        x:Name="DeclineButton"
                        Content="No thanks"
                        Width="110"
                        Height="34"
                        Margin="0,0,8,0"
                        Background="{DynamicResource CardBorderBrush}"
                        Foreground="{DynamicResource TextBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        Click="DeclineButton_Click"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="2"
                        x:Name="AcceptButton"
                        Content="Share usage data"
                        Width="150"
                        Height="34"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="White"
                        BorderBrush="{DynamicResource PrimaryBrush}"
                        Click="AcceptButton_Click"
                        Cursor="Hand"
                        IsDefault="True">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
