<Window x:Class="DesktopHub.UI.MetricsViewerOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Metrics Viewer"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        Width="740"
        Height="700"
        MinWidth="480"
        MinHeight="350"
        KeyDown="Window_KeyDown">

    <Grid>
        <!-- Resize grip borders (invisible hit-test zones on edges and corners) -->
        <Border x:Name="ResizeTop" Height="5" VerticalAlignment="Top" HorizontalAlignment="Stretch" Background="Transparent" Cursor="SizeNS"
                MouseLeftButtonDown="Resize_MouseDown" MouseLeftButtonUp="Resize_MouseUp" MouseMove="Resize_MouseMove" Tag="Top"/>
        <Border x:Name="ResizeBottom" Height="5" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Background="Transparent" Cursor="SizeNS"
                MouseLeftButtonDown="Resize_MouseDown" MouseLeftButtonUp="Resize_MouseUp" MouseMove="Resize_MouseMove" Tag="Bottom"/>
        <Border x:Name="ResizeLeft" Width="5" HorizontalAlignment="Left" VerticalAlignment="Stretch" Background="Transparent" Cursor="SizeWE"
                MouseLeftButtonDown="Resize_MouseDown" MouseLeftButtonUp="Resize_MouseUp" MouseMove="Resize_MouseMove" Tag="Left"/>
        <Border x:Name="ResizeRight" Width="5" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="Transparent" Cursor="SizeWE"
                MouseLeftButtonDown="Resize_MouseDown" MouseLeftButtonUp="Resize_MouseUp" MouseMove="Resize_MouseMove" Tag="Right"/>

        <Border x:Name="ResizeTopLeft" Width="8" Height="8" VerticalAlignment="Top" HorizontalAlignment="Left" Background="Transparent" Cursor="SizeNWSE"
                MouseLeftButtonDown="Resize_MouseDown" MouseLeftButtonUp="Resize_MouseUp" MouseMove="Resize_MouseMove" Tag="TopLeft"/>
        <Border x:Name="ResizeTopRight" Width="8" Height="8" VerticalAlignment="Top" HorizontalAlignment="Right" Background="Transparent" Cursor="SizeNESW"
                MouseLeftButtonDown="Resize_MouseDown" MouseLeftButtonUp="Resize_MouseUp" MouseMove="Resize_MouseMove" Tag="TopRight"/>
        <Border x:Name="ResizeBottomLeft" Width="8" Height="8" VerticalAlignment="Bottom" HorizontalAlignment="Left" Background="Transparent" Cursor="SizeNESW"
                MouseLeftButtonDown="Resize_MouseDown" MouseLeftButtonUp="Resize_MouseUp" MouseMove="Resize_MouseMove" Tag="BottomLeft"/>
        <Border x:Name="ResizeBottomRight" Width="8" Height="8" VerticalAlignment="Bottom" HorizontalAlignment="Right" Background="Transparent" Cursor="SizeNWSE"
                MouseLeftButtonDown="Resize_MouseDown" MouseLeftButtonUp="Resize_MouseUp" MouseMove="Resize_MouseMove" Tag="BottomRight"/>

        <!-- Main content -->
        <Border x:Name="RootBorder"
                Background="{DynamicResource WindowBackgroundAlphaBrush}"
                CornerRadius="12"
                BorderBrush="{DynamicResource WindowBorderBrush}"
                BorderThickness="1"
                Margin="3">
            <Grid>
                <Border Style="{StaticResource GlassOverlayBorder}"/>

                <Border Background="Transparent" Padding="18">
                    <ContentPresenter x:Name="WidgetHost"/>
                </Border>

                <Ellipse x:Name="UpdateIndicator"
                         Width="10" Height="10"
                         Fill="{DynamicResource GreenBrush}"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Bottom"
                         Margin="0,0,8,8"
                         Visibility="Collapsed"
                         IsHitTestVisible="False"/>

                <!-- Subtle resize grip indicator (bottom-right) -->
                <Canvas Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,12,12"
                        IsHitTestVisible="False" Opacity="0.3">
                    <Line X1="9" Y1="1" X2="1" Y2="9" Stroke="{DynamicResource TextTertiaryBrush}" StrokeThickness="1"/>
                    <Line X1="9" Y1="4" X2="4" Y2="9" Stroke="{DynamicResource TextTertiaryBrush}" StrokeThickness="1"/>
                    <Line X1="9" Y1="7" X2="7" Y2="9" Stroke="{DynamicResource TextTertiaryBrush}" StrokeThickness="1"/>
                </Canvas>
            </Grid>
        </Border>
    </Grid>
</Window>
