<Window x:Class="DesktopHub.UI.DeveloperPanelOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Developer Panel"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="860"
        Height="720"
        Topmost="True"
        KeyDown="Window_KeyDown">
    <Border x:Name="RootBorder"
            Background="{DynamicResource WindowBackgroundAlphaBrush}"
            CornerRadius="12"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="1">
        <Grid>
            <Border Style="{StaticResource GlassOverlayBorder}"/>

            <Border Background="Transparent" Padding="14">
                <ContentControl x:Name="WidgetHost" HorizontalAlignment="Stretch"/>
            </Border>

            <Ellipse x:Name="UpdateIndicator"
                     Width="10"
                     Height="10"
                     Fill="{DynamicResource GreenBrush}"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Margin="0,0,8,8"
                     Visibility="Collapsed"
                     IsHitTestVisible="False"/>
        </Grid>
    </Border>
</Window>
