<Window x:Class="DesktopHub.UI.WelcomeWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to DesktopHub"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Width="640"
        Height="520"
        Topmost="True"
        ShowInTaskbar="True">

    <Window.Resources>
        <Style x:Key="PresetCardStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Background" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SkipButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Background="{DynamicResource WindowBackgroundDeepBrush}"
            CornerRadius="12"
            BorderBrush="{DynamicResource WindowBorderSolidBrush}"
            BorderThickness="1">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Welcome to DesktopHub"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,8"/>

            <TextBlock Grid.Row="1"
                       TextWrapping="Wrap"
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,20">
                <Run Text="Pick a starting preset. You can change or extend this any time in Settings."/>
            </TextBlock>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button x:Name="PersonalCard" Grid.Row="0" Grid.Column="0"
                        Style="{StaticResource PresetCardStyle}"
                        Click="OnPersonal_Click">
                    <StackPanel>
                        <TextBlock Text="📁 Personal" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}">
                            <Run Text="Index your Documents folder as regular files. Good for home use. No project-number patterns needed."/>
                        </TextBlock>
                    </StackPanel>
                </Button>

                <Button x:Name="CesCard" Grid.Row="0" Grid.Column="2"
                        Style="{StaticResource PresetCardStyle}"
                        Click="OnCes_Click">
                    <StackPanel>
                        <TextBlock Text="🏢 Engineering (CES)" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}">
                            <Run Text="Florida (Q:), Connecticut (P:), CT Legacy (L:), and CT Archive. Matches the CES drive layout and MEP project numbering."/>
                        </TextBlock>
                    </StackPanel>
                </Button>

                <Button x:Name="GenericCard" Grid.Row="2" Grid.Column="0"
                        Style="{StaticResource PresetCardStyle}"
                        Click="OnGeneric_Click">
                    <StackPanel>
                        <TextBlock Text="📊 Generic Numbered Projects" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}">
                            <Run Text="YYYY-NNN style project folders under yearly directories. Starts disabled — you fill in the root path."/>
                        </TextBlock>
                    </StackPanel>
                </Button>

                <Button x:Name="BlankCard" Grid.Row="2" Grid.Column="2"
                        Style="{StaticResource PresetCardStyle}"
                        Click="OnBlank_Click">
                    <StackPanel>
                        <TextBlock Text="➕ Start Blank" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}">
                            <Run Text="No profiles. The app runs idle until you add one in Settings. Use this if you want to build your own config."/>
                        </TextBlock>
                    </StackPanel>
                </Button>
            </Grid>

            <Grid Grid.Row="3" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="You can re-open this wizard by deleting your settings.json"/>
                <Button Grid.Column="1"
                        Style="{StaticResource SkipButtonStyle}"
                        Content="Skip for now"
                        Click="OnSkip_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
