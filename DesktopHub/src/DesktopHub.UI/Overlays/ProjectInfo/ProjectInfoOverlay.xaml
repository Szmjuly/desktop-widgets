<Window x:Class="DesktopHub.UI.ProjectInfoOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Project Info"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="350"
        Height="520"
        Topmost="True"
        KeyDown="Window_KeyDown">
    
    <Border x:Name="RootBorder"
            Background="{DynamicResource WindowBackgroundAlphaBrush}"
            CornerRadius="12"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="1">
        <Grid HorizontalAlignment="Stretch">
            <!-- Glass overlay effect -->
            <Border Style="{StaticResource GlassOverlayBorder}"/>
            
            <!-- Content -->
            <Border Background="Transparent" Padding="12">
                <ContentControl x:Name="WidgetHost" HorizontalAlignment="Stretch"/>
            </Border>
            
            <!-- Update available indicator -->
            <Ellipse x:Name="UpdateIndicator"
                     Width="10" Height="10"
                     Fill="{DynamicResource GreenBrush}"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Margin="0,0,8,8"
                     Visibility="Collapsed"
                     IsHitTestVisible="False"/>
        </Grid>
    </Border>
</Window>
