<UserControl x:Class="DesktopHub.UI.Widgets.DeveloperPanelWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="520"
             MinHeight="360">
    <UserControl.Resources>
        <!-- Action button -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,5,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverMediumBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger button -->
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Foreground" Value="{DynamicResource RedBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{DynamicResource RedBackgroundBrush}"
                                BorderBrush="{DynamicResource RedBrush}" BorderThickness="1"
                                CornerRadius="5" Padding="{TemplateBinding Padding}" Opacity="0.8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource RedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed TextBox -->
        <Style x:Key="ThemedInput" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <!-- Themed ComboBox toggle button -->
        <ControlTemplate x:Key="ThemedComboBoxToggle" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Bd" Grid.ColumnSpan="2" Background="{DynamicResource InputBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"/>
                <Path x:Name="Arrow" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M 0 0 L 4 4 L 8 0 Z" Fill="{DynamicResource TextSecondaryBrush}"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                    <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Themed ComboBox -->
        <Style x:Key="ThemedComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="IsEditable" Value="True"/>
            <Setter Property="IsTextSearchEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Template="{StaticResource ThemedComboBoxToggle}"
                                          Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,4,24,4" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <TextBox x:Name="PART_EditableTextBox" Margin="6,3,24,3" Padding="2,1"
                                     HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                     Focusable="True" Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}"
                                     Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}"
                                     CaretBrush="{DynamicResource TextPrimaryBrush}" BorderThickness="0"
                                     FontFamily="Consolas" FontSize="11"/>
                            <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="False" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}" SnapsToDevicePixels="True">
                                    <Border x:Name="DropDownBorder" Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                                            Margin="0,1,0,0"/>
                                    <ScrollViewer Margin="2,4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="FontFamily" Value="Consolas"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="3">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverMediumBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section card -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Section header with icon -->
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <Style x:Key="CardSubtitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
        </Style>

        <!-- Rounded scrollbar for updates results -->
        <Style x:Key="ThemedScrollBarThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{DynamicResource HoverMediumBrush}" CornerRadius="6"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ThemedScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="2">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ThemedScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="12"/>
                    <Setter Property="Width" Value="Auto"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ROW 0: HEADER BAR (extra left padding nudges title block right vs. tab/content alignment) -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="18,8,14,8" Margin="0,0,0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border CornerRadius="4" Background="{DynamicResource AccentBrush}" Width="24" Height="24" Margin="0,0,8,0">
                    <TextBlock Text="D" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">
                        <Run Text="DesktopHub"/>
                        <Run Text=" Developer Console" FontWeight="Normal" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Ellipse x:Name="LiveDot" Width="7" Height="7" Fill="{DynamicResource GreenBrush}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LiveStatusText" Text="LIVE" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource GreenBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="ClockText" Grid.Column="4" Text="12:00:00" FontSize="11" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Border Grid.Column="5" CornerRadius="12" Padding="8,4" Background="{DynamicResource FaintOverlayBrush}">
                    <StackPanel Orientation="Horizontal">
                        <Border CornerRadius="10" Background="{DynamicResource AccentBrush}" Width="20" Height="20" Margin="0,0,6,0">
                            <TextBlock x:Name="UserInitialText" Text="S" FontSize="10" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="UsernameText" Text="" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Border x:Name="RoleBadge" CornerRadius="4" Padding="7,4" MinHeight="20" VerticalAlignment="Center"
                                Background="{DynamicResource BlueBackgroundBrush}">
                            <TextBlock x:Name="DevBadgeText" Text="DEV" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource BlueTextBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Border>
                <Button Grid.Column="6" ToolTip="Close panel"
                        Click="ClosePanel_Click"
                        Padding="0" Width="30" Height="30" Margin="10,0,0,0"
                        VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Cursor="Hand" Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource TextSecondaryBrush}">
                    <TextBlock Text="×" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               TextAlignment="Center" LineHeight="18" LineStackingStrategy="BlockLineHeight"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="-1"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="CloseBd" Background="Transparent" CornerRadius="6" Padding="0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              RecognizesAccessKey="False"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CloseBd" Property="Background" Value="{DynamicResource HoverMediumBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- Access denied overlay -->
        <Border x:Name="AccessDeniedPanel" Grid.Row="2" Background="{DynamicResource RedBackgroundBrush}" CornerRadius="8" Padding="16"
                Visibility="Collapsed" VerticalAlignment="Top" Panel.ZIndex="10">
            <TextBlock Text="Current user is not a DEV user. This panel is restricted." Foreground="{DynamicResource RedBrush}" TextWrapping="Wrap" FontSize="12"/>
        </Border>

        <!-- ROW 1: TAB BAR -->
        <WrapPanel x:Name="TabBar" Grid.Row="1" Margin="0,0,0,6"/>

        <!-- ROW 2: TAB CONTENT (only one visible at a time) -->
        <Grid x:Name="MainContent" Grid.Row="2">
            <!-- Dashboard Tab -->
            <Grid x:Name="DashboardTab" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- Health Overview card (Grid so inner * columns span full card width; StackPanel would shrink-wrap) -->
                <Border Style="{StaticResource SectionCard}">
                    <Grid x:Name="HealthOverviewPanel"/>
                </Border>
                <!-- Script Runner card -->
                <Border Grid.Row="1" Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Scripts" Style="{StaticResource CardTitle}" Margin="0,0,0,2"/>
                        <TextBlock Text="Choose a category, then a script tile." Style="{StaticResource CardSubtitle}" Margin="0,0,0,4"/>
                        <StackPanel x:Name="ScriptTileContainer"/>
                    </StackPanel>
                </Border>
                <!-- Bottom row: Version Info + System Status side by side -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource SectionCard}" Margin="0,0,4,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Version" Style="{StaticResource CardTitle}"/>
                                <Button Grid.Column="1" Content="Refresh" Style="{StaticResource ActionBtn}" Margin="0" Click="RefreshVersionInfo_Click"/>
                            </Grid>
                            <StackPanel x:Name="VersionInfoPanel"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource SectionCard}" Margin="4,0,0,0">
                        <StackPanel>
                            <TextBlock Text="System" Style="{StaticResource CardTitle}" Margin="0,0,0,4"/>
                            <StackPanel x:Name="SystemStatusPanel"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- Database Tab -->
            <Grid x:Name="DatabaseTab" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- Header row: title + actions -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Database Explorer" Style="{StaticResource CardTitle}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="NodeCountText" Style="{StaticResource CardSubtitle}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="Refresh" Style="{StaticResource ActionBtn}" Click="RefreshNodes_Click"/>
                        <Button x:Name="DbViewToggleBtn" Content="JSON" Style="{StaticResource ActionBtn}" Click="ToggleDbView_Click"/>
                        <Button Content="Get" Style="{StaticResource ActionBtn}" Click="GetNode_Click"/>
                        <Button Content="Set" Style="{StaticResource ActionBtn}" Click="SetNode_Click"/>
                        <Button Content="Delete" Style="{StaticResource DangerBtn}" Margin="0" Click="DeleteNode_Click"/>
                    </StackPanel>
                </Grid>
                <!-- Node pills + path -->
                <StackPanel Grid.Row="1">
                    <WrapPanel x:Name="NodePillsPanel" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Path" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,8,0"/>
                        <TextBox x:Name="NodePathBox" Grid.Column="1" Style="{StaticResource ThemedInput}" Text="app_versions/desktophub" FontSize="11"/>
                    </Grid>
                </StackPanel>
                <!-- Tree view / JSON view -->
                <Border Grid.Row="2" Style="{StaticResource SectionCard}" Padding="0" Margin="0">
                    <Grid>
                        <TreeView x:Name="DbTreeView" Background="Transparent" BorderThickness="0"
                                  Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Consolas" FontSize="11"
                                  Padding="8,6"/>
                        <TextBox x:Name="NodeJsonBox" Style="{StaticResource ThemedInput}"
                                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontSize="10"
                                 Visibility="Collapsed"/>
                        <ScrollViewer x:Name="ProjectTagsScroller" VerticalScrollBarVisibility="Auto" Padding="8,6"
                                      Visibility="Collapsed">
                            <StackPanel x:Name="ProjectTagsList"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Heartbeats Tab -->
            <Grid x:Name="HeartbeatsTab" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- Header with count + controls -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Active Heartbeats" Style="{StaticResource CardTitle}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="HeartbeatCountText" Grid.Column="1" Text="0 online" Style="{StaticResource CardSubtitle}"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock Text="Show" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox x:Name="HeartbeatRowCountBox" Width="52" SelectedIndex="1"
                                  Style="{StaticResource ThemedComboBox}" IsEditable="False"
                                  SelectionChanged="HeartbeatRowCount_Changed">
                            <ComboBoxItem Content="5"/>
                            <ComboBoxItem Content="10"/>
                            <ComboBoxItem Content="15"/>
                            <ComboBoxItem Content="20"/>
                        </ComboBox>
                    </StackPanel>
                    <Button Grid.Column="3" Content="Refresh" Style="{StaticResource ActionBtn}" Margin="0" Click="RefreshHeartbeats_Click"/>
                </Grid>
                <!-- Heartbeat list in scrollable fixed container -->
                <Border Grid.Row="1" Style="{StaticResource SectionCard}" Padding="6" Margin="0">
                    <ScrollViewer x:Name="HeartbeatScroller" VerticalScrollBarVisibility="Auto" MaxHeight="380">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                        </ScrollViewer.Resources>
                        <StackPanel x:Name="HeartbeatList"/>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Users / devices Tab -->
            <Grid x:Name="UsersDevicesTab" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Users &amp; devices" Style="{StaticResource CardTitle}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="UsersDevicesCountText" Style="{StaticResource CardSubtitle}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="Refresh" Style="{StaticResource ActionBtn}" Margin="0" Click="RefreshUsersDevices_Click"/>
                </Grid>
                <!-- Two-column: card grid + slide-in detail panel -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition x:Name="DetailPanelColumn" Width="0"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource SectionCard}" Padding="6" Margin="0">
                        <ScrollViewer x:Name="UsersDevicesScroller" VerticalScrollBarVisibility="Auto" MaxHeight="380"
                                      SizeChanged="UsersDevicesScroller_SizeChanged">
                            <ScrollViewer.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                            </ScrollViewer.Resources>
                            <UniformGrid x:Name="UsersDevicesList" Columns="4"/>
                        </ScrollViewer>
                    </Border>
                    <Border x:Name="UserDetailPanel" Grid.Column="1" Style="{StaticResource SectionCard}"
                            Padding="12,10" Margin="6,0,0,0" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="380">
                            <ScrollViewer.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                            </ScrollViewer.Resources>
                            <StackPanel x:Name="UserDetailContent"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <!-- Permissions Tab -->
            <Grid x:Name="PermissionsTab" Visibility="Collapsed">
                <Border Style="{StaticResource SectionCard}" Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="152"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Permissions" Style="{StaticResource CardTitle}" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Username" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,8,0"/>
                                <ComboBox x:Name="RoleUsernameBox" Grid.Column="1" Style="{StaticResource ThemedComboBox}" Margin="0,0,8,0"/>
                                <Button Grid.Column="2" Content="Normalize" Style="{StaticResource ActionBtn}" Margin="0" Click="NormalizeUsername_Click"/>
                            </Grid>
                            <TextBlock Text="This user" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="PermSelectedUserName" Text="—" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                            <WrapPanel x:Name="PermSelectedUserBadges" Margin="0,0,0,12"/>
                            <TextBlock Text="Change roles" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,4,0">
                                    <TextBlock Text="ADMIN" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource OrangeBrush}" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Add" Style="{StaticResource ActionBtn}" Click="AddAdmin_Click" Margin="0,0,4,4"/>
                                        <Button Content="Remove" Style="{StaticResource DangerBtn}" Click="RemoveAdmin_Click" Margin="0,0,0,4"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0,4,0">
                                    <TextBlock Text="EDITOR" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource GreenBrush}" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Add" Style="{StaticResource ActionBtn}" Click="AddEditor_Click" Margin="0,0,4,4"/>
                                        <Button Content="Remove" Style="{StaticResource DangerBtn}" Click="RemoveEditor_Click" Margin="0,0,0,4"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="4,0,0,0">
                                    <TextBlock Text="DEV" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource BlueBrush}" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Add" Style="{StaticResource ActionBtn}" Click="AddDev_Click" Margin="0,0,4,4"/>
                                        <Button Content="Remove" Style="{StaticResource DangerBtn}" Click="RemoveDev_Click" Margin="0,0,0,4"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                        <!-- Role directory counts (Firebase) -->
                        <Border Grid.Column="1" Background="{DynamicResource FaintOverlayBrush}" CornerRadius="8" Padding="10,8"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="Role directory" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                                <TextBlock Text="Members in Firebase" FontSize="9" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="PermDirAdminLine" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                <TextBlock x:Name="PermDirEditorLine" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                <TextBlock x:Name="PermDirDevLine" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <Button Content="Refresh counts" Style="{StaticResource ActionBtn}" Margin="0" Padding="8,4" FontSize="10" Click="RefreshPermDirectory_Click"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Updates Tab -->
            <Grid x:Name="UpdatesTab" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- Version management -->
                <Border Style="{StaticResource SectionCard}" Margin="0,0,0,6">
                    <StackPanel>
                        <TextBlock Text="Version Management" Style="{StaticResource CardTitle}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="App" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,8,0"/>
                            <ComboBox x:Name="UpdateAppBox" Grid.Column="1" Style="{StaticResource ThemedComboBox}" IsEditable="False"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Version" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,8,0"/>
                            <TextBox x:Name="UpdateVersionBox" Grid.Column="1" Style="{StaticResource ThemedInput}" FontSize="11" Margin="0,0,8,0"/>
                            <Button Grid.Column="2" Content="Publish" Style="{StaticResource ActionBtn}" Margin="0" Click="PublishVersion_Click"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Notes" VerticalAlignment="Top" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,8,0"/>
                            <TextBox x:Name="UpdateNotesBox" Grid.Column="1" Style="{StaticResource ThemedInput}" FontSize="11" Height="40" AcceptsReturn="True" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>
                <!-- Device push + build actions -->
                <Border Grid.Row="1" Style="{StaticResource SectionCard}" Margin="0,0,0,6">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Push Updates" Style="{StaticResource CardTitle}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="List Devices" Style="{StaticResource ActionBtn}" Click="ListDevices_Click"/>
                                <Button Content="Push All" Style="{StaticResource DangerBtn}" Margin="0,0,5,5" Click="PushUpdateAll_Click"/>
                                <Button Content="Check Status" Style="{StaticResource ActionBtn}" Click="CheckUpdateStatus_Click"/>
                                <Button Content="Clear Done" Style="{StaticResource ActionBtn}" Margin="0" Click="ClearUpdates_Click"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="User" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,8,0"/>
                            <ComboBox x:Name="PushUserFilterBox" Grid.Column="1" Width="150" Style="{StaticResource ThemedComboBox}" Margin="0,0,8,0" SelectionChanged="PushUserFilterBox_SelectionChanged"/>
                            <ComboBox x:Name="PushDeviceIdBox" Grid.Column="2" Style="{StaticResource ThemedComboBox}" FontSize="11" Margin="0,0,8,0"/>
                            <Button Grid.Column="3" Content="Push" Style="{StaticResource ActionBtn}" Margin="0" Click="PushUpdateDevice_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>
                <!-- Structured results (Firebase) above OUTPUT; scripts still append raw log below -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border x:Name="UpdateStructuredResultsBorder" Grid.Row="0" Style="{StaticResource SectionCard}" Margin="0,0,0,6"
                            Padding="10,8" Visibility="Collapsed">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="UpdateStructuredResultsTitle" Style="{StaticResource CardTitle}" Margin="0,0,0,2"/>
                                    <TextBlock Text="Live data from Firebase · full script transcript is in OUTPUT below."
                                               FontSize="9" Foreground="{DynamicResource TextTertiaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Dismiss" Style="{StaticResource ActionBtn}" Padding="8,4" Margin="8,0,0,0"
                                        VerticalAlignment="Top" FontSize="10" Click="DismissUpdateResults_Click"/>
                            </Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="240">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                                </ScrollViewer.Resources>
                                <StackPanel x:Name="UpdateStructuredResultsPanel"/>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource SectionCard}" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="Build Tools" Style="{StaticResource CardTitle}" Margin="0,0,0,6"/>
                            <WrapPanel>
                                <Button Content="Build" Style="{StaticResource ActionBtn}" Click="Build_Click"/>
                                <Button Content="Build Installer" Style="{StaticResource ActionBtn}" Click="BuildInstaller_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- Licensing Tab -->
            <Grid x:Name="LicensingTab" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Licensing" Style="{StaticResource CardTitle}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Refresh" Style="{StaticResource ActionBtn}" Margin="0" Click="RefreshLicenses_Click"/>
                </Grid>
                <Border Grid.Row="1" Style="{StaticResource SectionCard}" Margin="0,0,0,6">
                    <StackPanel>
                        <TextBlock Text="Create License" Style="{StaticResource CardTitle}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Key" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,8,0"/>
                            <TextBox x:Name="LicenseKeyBox" Grid.Column="1" Style="{StaticResource ThemedInput}" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="2" Text="Plan" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,8,0"/>
                            <ComboBox x:Name="LicensePlanBox" Grid.Column="3" Style="{StaticResource ThemedComboBox}" IsEditable="False"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="App" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,8,0"/>
                            <ComboBox x:Name="LicenseAppBox" Grid.Column="1" Style="{StaticResource ThemedComboBox}" IsEditable="False" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="2" Text="Max Devices" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,8,0"/>
                            <TextBox x:Name="LicenseMaxDevicesBox" Grid.Column="3" Style="{StaticResource ThemedInput}" Text="5"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Expires (ISO)" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,8,0"/>
                            <TextBox x:Name="LicenseExpiresAtBox" Grid.Column="1" Style="{StaticResource ThemedInput}" Margin="0,0,8,0"/>
                            <Button Grid.Column="2" Content="Create" Style="{StaticResource ActionBtn}" Margin="0" Click="CreateLicense_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>
                <Border Grid.Row="2" Style="{StaticResource SectionCard}" Padding="6">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="LicenseListPanel"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- ROW 3: OUTPUT CONSOLE -->
        <Border Grid.Row="3" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="6" Margin="0,6,0,0" Padding="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Margin="6,3,6,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="OUTPUT" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Clear" Style="{StaticResource ActionBtn}" Padding="8,2" Margin="0" FontSize="9" Click="ClearOutput_Click"/>
                </Grid>
                <TextBox x:Name="OutputBox"
                         Grid.Row="1"
                         Height="80"
                         Background="Transparent"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         CaretBrush="{DynamicResource TextPrimaryBrush}"
                         BorderThickness="0"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="10"
                         Padding="6,2">
                    <!-- ScrollBars live inside the TextBox template; scope resources here so they pick up the theme -->
                    <TextBox.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBar}"/>
                    </TextBox.Resources>
                </TextBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
