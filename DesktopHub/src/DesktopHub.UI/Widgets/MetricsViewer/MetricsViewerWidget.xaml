<UserControl x:Class="DesktopHub.UI.Widgets.MetricsViewerWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="{DynamicResource TextPrimaryBrush}">

    <UserControl.Resources>
        <SolidColorBrush x:Key="DimTextBrush" Color="{DynamicResource TextSecondaryColor}"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="{DynamicResource TextTertiaryColor}"/>

        <!-- Thin rounded scrollbar style -->
        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="5"/>
            <Setter Property="MinWidth" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="{DynamicResource SelectedBrush}" CornerRadius="2.5" Margin="0,1"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ThinScrollViewer" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1" x:Name="PART_VerticalScrollBar"
                                       Style="{StaticResource ThinScrollBar}"
                                       Margin="4,0,0,0"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" Text="Metrics"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <Ellipse x:Name="PollingIndicator"
                         Width="6" Height="6"
                         Fill="{DynamicResource GreenBrush}"
                         Margin="6,0,0,0"
                         VerticalAlignment="Center"
                         ToolTip="Auto-refreshing"
                         Visibility="Collapsed"/>
            </StackPanel>

            <!-- Admin view toggle (only visible in admin builds) -->
            <Border x:Name="AdminToggleButton"
                    Grid.Column="1"
                    Background="{DynamicResource HoverBrush}"
                    BorderBrush="{DynamicResource SelectedBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Cursor="Hand"
                    Padding="6,4"
                    Margin="0,0,6,0"
                    ToolTip="Toggle admin view (all users)"
                    Visibility="Collapsed"
                    MouseLeftButtonDown="AdminToggle_Click">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverMediumBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock x:Name="AdminToggleIcon" Text="&#x1F464;"
                           FontSize="12"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           ToolTip="Single user view"/>
            </Border>

            <!-- Refresh button -->
            <Border Grid.Column="2"
                    Background="{DynamicResource HoverBrush}"
                    BorderBrush="{DynamicResource SelectedBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Cursor="Hand"
                    Padding="6,4"
                    Margin="0,0,6,0"
                    ToolTip="Refresh metrics now"
                    MouseLeftButtonDown="RefreshButton_Click">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverMediumBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="&#x21BB;"
                           FontSize="14"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
            </Border>

            <!-- Close button -->
            <Border Grid.Column="3"
                    Background="{DynamicResource HoverBrush}"
                    BorderBrush="{DynamicResource SelectedBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Cursor="Hand"
                    Padding="6,4"
                    MouseLeftButtonDown="CloseButton_Click">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverMediumBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="&#x2715;"
                           FontSize="14"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <!-- Content area -->
        <Grid Grid.Row="1">
            <!-- Single-user view (default) — three columns for wider layout -->
            <Grid x:Name="SingleViewPanel">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left column: device, date, session, search, activity -->
                <ScrollViewer Grid.Column="0" Style="{StaticResource ThinScrollViewer}" Margin="0,0,4,0">
                    <StackPanel>
                        <!-- Device info bar -->
                        <Border Background="{DynamicResource FaintOverlayBrush}" CornerRadius="4" Padding="8,4" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#x1F4BB;" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock x:Name="DeviceInfoLabel"
                                           Grid.Column="1"
                                           Text=""
                                           FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           ToolTip="This device's identity for metrics tracking"/>
                            </Grid>
                        </Border>

                        <!-- Date selector -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="{DynamicResource HoverBrush}"
                                    CornerRadius="4"
                                    Padding="6,3"
                                    Cursor="Hand"
                                    Margin="0,0,4,0"
                                    MouseLeftButtonDown="PrevDay_Click">
                                <TextBlock Text="&#x25C0;" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock x:Name="DateLabel"
                                       Grid.Column="1"
                                       Text="Today"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="4,0"/>

                            <Border Grid.Column="3"
                                    Background="{DynamicResource HoverBrush}"
                                    CornerRadius="4"
                                    Padding="6,3"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="NextDay_Click">
                                <TextBlock Text="&#x25B6;" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Usage Insights card -->
                        <Border Background="{DynamicResource AccentLightBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Derived insights from your usage patterns.">
                            <StackPanel>
                                <TextBlock Text="INSIGHTS" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock x:Name="InsightScoreLabel" Text="--" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource GreenBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="score" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock x:Name="InsightPeakLabel" Text="--" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BlueBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="peak hr" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock x:Name="InsightStreakLabel" Text="--" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource OrangeBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="streak" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock x:Name="InsightAvgDurLabel" Text="--" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="avg sess" FontSize="8" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock x:Name="InsightActiveDaysLabel" Text="--" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="active/7d" FontSize="8" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock x:Name="InsightTopFeatureLabel" Text="--" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="top feat." FontSize="8" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Session summary card -->
                        <Border Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Sessions = number of times the app was launched on this device.&#x0a;Total time = sum of all session durations on this device.">
                            <StackPanel>
                                <TextBlock Text="SESSION" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock x:Name="SessionCountLabel" Text="0" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="sessions" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock x:Name="SessionDurationLabel" Text="0m" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="total time" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Search metrics -->
                        <Border Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Search counts = total queries typed.&#x0a;Project = main overlay, Smart = smart file search, Doc = doc quick open, Path = path-scoped.">
                            <StackPanel>
                                <TextBlock Text="SEARCH" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock x:Name="ProjectSearchCount" Text="0" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="project" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock x:Name="SmartSearchCount" Text="0" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="smart" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock x:Name="DocSearchCount" Text="0" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="doc" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                        <TextBlock x:Name="PathSearchCount" Text="0" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="path" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Cheat sheet metrics -->
                        <Border Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Cheat Sheets widget: views, lookups, copies, and searches for this day.">
                            <StackPanel>
                                <TextBlock Text="CHEAT SHEET METRICS" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock x:Name="CheatSheetViewsCount" Text="0" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="views" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock x:Name="CheatSheetLookupsCount" Text="0" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="lookups" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock x:Name="CheatSheetCopiesCount" Text="0" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="copies" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                        <TextBlock x:Name="CheatSheetSearchesCount" Text="0" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="searches" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel x:Name="CheatSheetTopSheetsPanel" Margin="0,4,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                        <!-- Activity metrics -->
                        <Border Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="ACTIVITY" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                <StackPanel x:Name="ActivityRows"/>
                            </StackPanel>
                        </Border>

                        <!-- Performance metrics -->
                        <Border x:Name="PerformanceCard" Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                Visibility="Collapsed"
                                ToolTip="App performance timing averages for this day.">
                            <StackPanel>
                                <TextBlock Text="PERFORMANCE" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                <StackPanel x:Name="PerformanceRows"/>
                            </StackPanel>
                        </Border>

                        <!-- Disciplines breakdown -->
                        <Border x:Name="DisciplinesCard" Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                Visibility="Collapsed"
                                ToolTip="Building disciplines you worked with today.">
                            <StackPanel>
                                <TextBlock Text="DISCIPLINES" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                <WrapPanel x:Name="DisciplinePills" Orientation="Horizontal"/>
                            </StackPanel>
                        </Border>

                        <!-- Project types breakdown -->
                        <Border x:Name="ProjectTypesCard" Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                Visibility="Collapsed"
                                ToolTip="Types of projects accessed today.">
                            <StackPanel>
                                <TextBlock Text="PROJECT TYPES" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                <WrapPanel x:Name="ProjectTypePills" Orientation="Horizontal"/>
                            </StackPanel>
                        </Border>

                        <!-- File types breakdown -->
                        <Border x:Name="FileTypesCard" Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                Visibility="Collapsed"
                                ToolTip="Document file types opened today.">
                            <StackPanel>
                                <TextBlock Text="FILE TYPES" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                <WrapPanel x:Name="FileTypePills" Orientation="Horizontal"/>
                            </StackPanel>
                        </Border>

                        <!-- All metrics flat list -->
                        <Border x:Name="AllMetricsCard" Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Complete list of every tracked metric for this day.">
                            <StackPanel>
                                <TextBlock Text="ALL METRICS" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                <StackPanel x:Name="AllMetricsRows"/>
                            </StackPanel>
                        </Border>

                        <!-- Status -->
                        <TextBlock x:Name="StatusText"
                                   Text=""
                                   FontSize="10"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Middle column: chart areas use star rows so they fill space and redraw to size -->
                <ScrollViewer Grid.Column="1" x:Name="MiddleColumnScroll" Style="{StaticResource ThinScrollViewer}" Margin="4,0,4,0">
                    <Grid Height="{Binding ViewportHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Hourly activity heatmap -->
                        <Border Grid.Row="0" Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Event count per hour for this day. Brighter = more activity.">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="HOURLY ACTIVITY" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                <Canvas Grid.Row="1" x:Name="HourlyHeatmapCanvas" MinHeight="50" ClipToBounds="True"/>
                                <TextBlock Grid.Row="2" x:Name="HourlyPeakLabel" Text="" FontSize="9" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,0"/>
                            </Grid>
                        </Border>
                        <!-- 7-Day Trend sparklines (fixed height content) -->
                        <Border Grid.Row="1" Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Mini trend lines for the past 7 days.">
                            <StackPanel>
                                <TextBlock Text="7-DAY TRENDS" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                <StackPanel x:Name="TrendSparklines"/>
                            </StackPanel>
                        </Border>
                        <!-- Feature breakdown donut -->
                        <Border Grid.Row="2" Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Breakdown of how you spent your time across features.">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="FEATURE BREAKDOWN" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                <Canvas Grid.Row="1" x:Name="FeatureDonutCanvas" MinHeight="130" ClipToBounds="True"/>
                                <StackPanel Grid.Row="2" x:Name="FeatureDonutLegend" Margin="0,4,0,0"/>
                            </Grid>
                        </Border>
                        <!-- Activity Flow (feature transitions) -->
                        <Border Grid.Row="3" Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="How you move between features during sessions.">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="ACTIVITY FLOW" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                <Canvas Grid.Row="1" x:Name="ActivityFlowCanvas" MinHeight="120" ClipToBounds="True"/>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>

                <!-- Right column: top queries, top projects, widget usage, session timeline -->
                <ScrollViewer Grid.Column="2" Style="{StaticResource ThinScrollViewer}" Margin="4,0,0,0">
                    <StackPanel>
                        <!-- Top queries -->
                        <Border Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Unique search terms ranked by frequency for this day.">
                            <StackPanel>
                                <TextBlock Text="TOP QUERIES" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                <StackPanel x:Name="TopQueriesPanel"/>
                            </StackPanel>
                        </Border>

                        <!-- Top projects -->
                        <Border Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Most accessed projects in the last 7 days.">
                            <StackPanel>
                                <TextBlock Text="TOP PROJECTS (7d)" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                <StackPanel x:Name="TopProjectsPanel"/>
                            </StackPanel>
                        </Border>

                        <!-- Widget usage breakdown -->
                        <Border Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Total events recorded per widget for this day.">
                            <StackPanel>
                                <TextBlock Text="WIDGET USAGE" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                <StackPanel x:Name="WidgetUsageRows"/>
                            </StackPanel>
                        </Border>

                        <!-- Session timeline -->
                        <Border Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Individual sessions with duration and actions.">
                            <StackPanel>
                                <TextBlock Text="SESSION TIMELINE" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                <StackPanel x:Name="SessionTimelinePanel"/>
                            </StackPanel>
                        </Border>

                        <!-- Weekly comparison -->
                        <Border Background="{DynamicResource AccentLightBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="This week vs last week comparison.">
                            <StackPanel>
                                <TextBlock Text="WEEKLY COMPARISON" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                <StackPanel x:Name="WeeklyComparisonPanel"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Admin multi-user view (hidden by default, shown in admin builds) -->
            <Grid x:Name="AdminViewPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Admin header + date range -->
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource OrangeBackgroundBrush}" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ADMIN" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource OrangeBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="AdminUserCountLabel" Text="All users" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="{DynamicResource HoverBrush}" CornerRadius="4" Padding="6,3" Cursor="Hand" MouseLeftButtonDown="AdminPrevRange_Click">
                        <TextBlock Text="&#x25C0;" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="AdminDateRangeLabel" Grid.Column="3" Text="Last 7 days" FontSize="11" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="8,0"/>
                    <Border Grid.Column="4" Background="{DynamicResource HoverBrush}" CornerRadius="4" Padding="6,3" Cursor="Hand" MouseLeftButtonDown="AdminNextRange_Click">
                        <TextBlock Text="&#x25B6;" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <!-- Row 1: Section label — Filters & chart -->
                <TextBlock Grid.Row="1" Text="FILTERS &amp; CHART" FontSize="8" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,2"/>

                <!-- Row 2: User toggle pills (show/hide individual users) -->
                <Border Grid.Row="2" Background="{DynamicResource FaintOverlayBrush}" CornerRadius="6" Padding="10,6" Margin="0,0,0,6">
                    <StackPanel>
                        <TextBlock Text="USERS (click to toggle)" FontSize="8" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,4"/>
                        <WrapPanel x:Name="UserTogglePanel" Orientation="Horizontal"/>
                    </StackPanel>
                </Border>

                <!-- Row 3: Metric selectors (dynamic based on chart type) -->
                <Border x:Name="MetricSelectorBorder" Grid.Row="3" Background="{DynamicResource FaintOverlayBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                    <StackPanel x:Name="MetricSelectorPanel"/>
                </Border>

                <!-- Row 4: Chart type selector -->
                <Border Grid.Row="4" Background="{DynamicResource FaintOverlayBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                    <WrapPanel x:Name="ChartTypeButtons" Orientation="Horizontal"/>
                </Border>

                <!-- Row 5: Section label — Analysis -->
                <TextBlock Grid.Row="5" Text="ANALYSIS" FontSize="8" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,2"/>

                <!-- Row 6: Main content — three columns: chart, user summary, insights -->
                <Grid Grid.Row="6" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Column 0: Chart -->
                    <Border Grid.Column="0" Background="{DynamicResource FaintOverlayBrush}" CornerRadius="6" Padding="8" Margin="0,0,4,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Canvas Grid.Row="0" x:Name="ChartCanvas" MinHeight="180" ClipToBounds="True"/>
                            <TextBlock x:Name="ChartEmptyLabel" Text="Select a chart type above" FontSize="11" FontStyle="Italic"
                                       Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Column 1: User summary -->
                    <Border Grid.Column="1" Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="4,0,4,0">
                        <ScrollViewer Style="{StaticResource ThinScrollViewer}">
                            <StackPanel>
                                <TextBlock Text="USER SUMMARY" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                <StackPanel x:Name="AdminSummaryRows"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- Column 2: Tabbed right panel -->
                    <Grid Grid.Column="2" Margin="4,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Tab bar -->
                        <StackPanel x:Name="AdminRightTabBar" Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6"/>

                        <!-- Tab: Overview (existing content) -->
                        <ScrollViewer x:Name="AdminOverviewTab" Grid.Row="1" Style="{StaticResource ThinScrollViewer}">
                            <StackPanel>
                                <Border Background="{DynamicResource AccentLightBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                        ToolTip="Auto-generated insights from the selected data.">
                                    <StackPanel>
                                        <TextBlock Text="INSIGHTS" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                        <StackPanel x:Name="AdminInsightCalloutsPanel"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="{DynamicResource FaintOverlayBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="COMPARISONS" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                        <TextBlock Text="User A" FontSize="8" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                        <ComboBox x:Name="AdminCompareUserA" Margin="0,0,0,6" FontSize="10" MinWidth="90"
                                                 Style="{StaticResource ThemedComboBox}" ItemContainerStyle="{StaticResource ThemedComboBoxItem}"/>
                                        <TextBlock Text="vs User B" FontSize="8" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                        <ComboBox x:Name="AdminCompareUserB" Margin="0,0,0,6" FontSize="10" MinWidth="90"
                                                 Style="{StaticResource ThemedComboBox}" ItemContainerStyle="{StaticResource ThemedComboBoxItem}"/>
                                        <StackPanel x:Name="AdminUserComparisonResultPanel" Margin="0,2,0,0"/>
                                        <TextBlock Text="Period vs previous" FontSize="8" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,8,0,2"/>
                                        <StackPanel x:Name="AdminPeriodComparisonPanel" Margin="0,0,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8" MinHeight="140">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="ACTIVITY FLOW" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                        <Canvas Grid.Row="1" x:Name="AdminFlowCanvas" MinHeight="120" ClipToBounds="True"/>
                                    </Grid>
                                </Border>
                                <Border Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="TOP PROJECTS" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                        <StackPanel x:Name="AdminTopProjectsPanel"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="FEATURE USAGE" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                        <StackPanel x:Name="AdminFeatureRows"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                        ToolTip="Cheat Sheets widget usage across selected users and period.">
                                    <StackPanel>
                                        <TextBlock Text="CHEAT SHEET METRICS" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                                        <StackPanel x:Name="AdminCheatSheetPanel"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Tab: Category Detail -->
                        <ScrollViewer x:Name="AdminCategoryDetailTab" Grid.Row="1" Style="{StaticResource ThinScrollViewer}" Visibility="Collapsed">
                            <StackPanel>
                                <WrapPanel x:Name="CategorySelectorPills" Orientation="Horizontal" Margin="0,0,0,8"/>
                                <StackPanel x:Name="CategoryDetailContent"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- Row 7: Admin status -->
                <TextBlock Grid.Row="7" x:Name="AdminStatusText"
                           Text=""
                           FontSize="10"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           HorizontalAlignment="Center"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
