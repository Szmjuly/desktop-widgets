<UserControl x:Class="DesktopHub.UI.Widgets.MetricsViewerWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="#F5F7FA">

    <UserControl.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#F5F7FA"/>
        <SolidColorBrush x:Key="DimTextBrush" Color="#B6C3CA"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6B7A85"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#007ACC"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#10F5F7FA"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#20F5F7FA"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#66BB6A"/>
        <SolidColorBrush x:Key="OrangeBrush" Color="#FFA726"/>
        <SolidColorBrush x:Key="PurpleBrush" Color="#AB47BC"/>

        <!-- Thin rounded scrollbar style -->
        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="5"/>
            <Setter Property="MinWidth" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="#30F5F7FA" CornerRadius="2.5" Margin="0,1"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ThinScrollViewer" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1" x:Name="PART_VerticalScrollBar"
                                       Style="{StaticResource ThinScrollBar}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" Text="Metrics"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#F5F7FA"
                           VerticalAlignment="Center"/>
                <Ellipse x:Name="PollingIndicator"
                         Width="6" Height="6"
                         Fill="#4CAF50"
                         Margin="6,0,0,0"
                         VerticalAlignment="Center"
                         ToolTip="Auto-refreshing"
                         Visibility="Collapsed"/>
            </StackPanel>

            <!-- Admin view toggle (only visible in admin builds) -->
            <Border x:Name="AdminToggleButton"
                    Grid.Column="1"
                    Background="#10F5F7FA"
                    BorderBrush="#30F5F7FA"
                    BorderThickness="1"
                    CornerRadius="4"
                    Cursor="Hand"
                    Padding="6,4"
                    Margin="0,0,6,0"
                    ToolTip="Toggle admin view (all users)"
                    Visibility="Collapsed"
                    MouseLeftButtonDown="AdminToggle_Click">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#25F5F7FA"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock x:Name="AdminToggleIcon" Text="&#x1F464;"
                           FontSize="12"
                           Foreground="#F5F7FA"
                           ToolTip="Single user view"/>
            </Border>

            <!-- Refresh button -->
            <Border Grid.Column="2"
                    Background="#10F5F7FA"
                    BorderBrush="#30F5F7FA"
                    BorderThickness="1"
                    CornerRadius="4"
                    Cursor="Hand"
                    Padding="6,4"
                    Margin="0,0,6,0"
                    ToolTip="Refresh metrics now"
                    MouseLeftButtonDown="RefreshButton_Click">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#25F5F7FA"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="&#x21BB;"
                           FontSize="14"
                           Foreground="#F5F7FA"/>
            </Border>

            <!-- Close button -->
            <Border Grid.Column="3"
                    Background="#10F5F7FA"
                    BorderBrush="#30F5F7FA"
                    BorderThickness="1"
                    CornerRadius="4"
                    Cursor="Hand"
                    Padding="6,4"
                    MouseLeftButtonDown="CloseButton_Click">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#25F5F7FA"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="&#x2715;"
                           FontSize="14"
                           Foreground="#F5F7FA"
                           FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <!-- Content area -->
        <Grid Grid.Row="1">
            <!-- Single-user view (default) — three columns for wider layout -->
            <Grid x:Name="SingleViewPanel">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left column: device, date, session, search, activity -->
                <ScrollViewer Grid.Column="0" Style="{StaticResource ThinScrollViewer}" Margin="0,0,4,0">
                    <StackPanel>
                        <!-- Device info bar -->
                        <Border Background="#08F5F7FA" CornerRadius="4" Padding="8,4" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#x1F4BB;" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock x:Name="DeviceInfoLabel"
                                           Grid.Column="1"
                                           Text=""
                                           FontSize="10"
                                           Foreground="#8899A6"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           ToolTip="This device's identity for metrics tracking"/>
                            </Grid>
                        </Border>

                        <!-- Date selector -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="#10F5F7FA"
                                    CornerRadius="4"
                                    Padding="6,3"
                                    Cursor="Hand"
                                    Margin="0,0,4,0"
                                    MouseLeftButtonDown="PrevDay_Click">
                                <TextBlock Text="&#x25C0;" FontSize="10" Foreground="#B6C3CA" VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock x:Name="DateLabel"
                                       Grid.Column="1"
                                       Text="Today"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       Foreground="#F5F7FA"
                                       VerticalAlignment="Center"
                                       Margin="4,0"/>

                            <Border Grid.Column="3"
                                    Background="#10F5F7FA"
                                    CornerRadius="4"
                                    Padding="6,3"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="NextDay_Click">
                                <TextBlock Text="&#x25B6;" FontSize="10" Foreground="#B6C3CA" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Usage Insights card -->
                        <Border Background="#10007ACC" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Derived insights from your usage patterns.">
                            <StackPanel>
                                <TextBlock Text="INSIGHTS" FontSize="9" FontWeight="SemiBold" Foreground="#80B6C3CA" Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock x:Name="InsightScoreLabel" Text="--" FontSize="20" FontWeight="Bold" Foreground="#66BB6A" HorizontalAlignment="Center"/>
                                        <TextBlock Text="score" FontSize="9" Foreground="#B6C3CA" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock x:Name="InsightPeakLabel" Text="--" FontSize="20" FontWeight="Bold" Foreground="#42A5F5" HorizontalAlignment="Center"/>
                                        <TextBlock Text="peak hr" FontSize="9" Foreground="#B6C3CA" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock x:Name="InsightStreakLabel" Text="--" FontSize="20" FontWeight="Bold" Foreground="#FFA726" HorizontalAlignment="Center"/>
                                        <TextBlock Text="streak" FontSize="9" Foreground="#B6C3CA" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock x:Name="InsightAvgDurLabel" Text="--" FontSize="14" FontWeight="SemiBold" Foreground="#F5F7FA" HorizontalAlignment="Center"/>
                                        <TextBlock Text="avg sess" FontSize="8" Foreground="#6B7A85" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock x:Name="InsightActiveDaysLabel" Text="--" FontSize="14" FontWeight="SemiBold" Foreground="#F5F7FA" HorizontalAlignment="Center"/>
                                        <TextBlock Text="active/7d" FontSize="8" Foreground="#6B7A85" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock x:Name="InsightTopFeatureLabel" Text="--" FontSize="10" FontWeight="SemiBold" Foreground="#F5F7FA" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="top feat." FontSize="8" Foreground="#6B7A85" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Session summary card -->
                        <Border Background="#10F5F7FA" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Sessions = number of times the app was launched on this device.&#x0a;Total time = sum of all session durations on this device.">
                            <StackPanel>
                                <TextBlock Text="SESSION" FontSize="9" FontWeight="SemiBold" Foreground="#80B6C3CA" Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock x:Name="SessionCountLabel" Text="0" FontSize="22" FontWeight="Bold" Foreground="#F5F7FA"/>
                                        <TextBlock Text="sessions" FontSize="10" Foreground="#B6C3CA"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock x:Name="SessionDurationLabel" Text="0m" FontSize="22" FontWeight="Bold" Foreground="#F5F7FA"/>
                                        <TextBlock Text="total time" FontSize="10" Foreground="#B6C3CA"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Search metrics -->
                        <Border Background="#10F5F7FA" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Search counts = total queries typed.&#x0a;Project = main overlay, Smart = smart file search, Doc = doc quick open, Path = path-scoped.">
                            <StackPanel>
                                <TextBlock Text="SEARCH" FontSize="9" FontWeight="SemiBold" Foreground="#80B6C3CA" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock x:Name="ProjectSearchCount" Text="0" FontSize="18" FontWeight="Bold" Foreground="#F5F7FA" HorizontalAlignment="Center"/>
                                        <TextBlock Text="project" FontSize="9" Foreground="#B6C3CA" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock x:Name="SmartSearchCount" Text="0" FontSize="18" FontWeight="Bold" Foreground="#F5F7FA" HorizontalAlignment="Center"/>
                                        <TextBlock Text="smart" FontSize="9" Foreground="#B6C3CA" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock x:Name="DocSearchCount" Text="0" FontSize="18" FontWeight="Bold" Foreground="#F5F7FA" HorizontalAlignment="Center"/>
                                        <TextBlock Text="doc" FontSize="9" Foreground="#B6C3CA" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                        <TextBlock x:Name="PathSearchCount" Text="0" FontSize="18" FontWeight="Bold" Foreground="#F5F7FA" HorizontalAlignment="Center"/>
                                        <TextBlock Text="path" FontSize="9" Foreground="#B6C3CA" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Activity metrics -->
                        <Border Background="#10F5F7FA" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="ACTIVITY" FontSize="9" FontWeight="SemiBold" Foreground="#80B6C3CA" Margin="0,0,0,6"/>
                                <StackPanel x:Name="ActivityRows"/>
                            </StackPanel>
                        </Border>

                        <!-- Status -->
                        <TextBlock x:Name="StatusText"
                                   Text=""
                                   FontSize="10"
                                   Foreground="#6B7A85"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Middle column: hourly heatmap, 7-day trends, feature breakdown, session timeline -->
                <ScrollViewer Grid.Column="1" Style="{StaticResource ThinScrollViewer}" Margin="4,0,4,0">
                    <StackPanel>
                        <!-- Hourly activity heatmap -->
                        <Border Background="#10F5F7FA" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Event count per hour for this day. Brighter = more activity.">
                            <StackPanel>
                                <TextBlock Text="HOURLY ACTIVITY" FontSize="9" FontWeight="SemiBold" Foreground="#80B6C3CA" Margin="0,0,0,6"/>
                                <Canvas x:Name="HourlyHeatmapCanvas" Height="50" ClipToBounds="True"/>
                                <TextBlock x:Name="HourlyPeakLabel" Text="" FontSize="9" Foreground="#6B7A85" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- 7-Day Trend sparklines -->
                        <Border Background="#10F5F7FA" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Mini trend lines for the past 7 days.">
                            <StackPanel>
                                <TextBlock Text="7-DAY TRENDS" FontSize="9" FontWeight="SemiBold" Foreground="#80B6C3CA" Margin="0,0,0,6"/>
                                <StackPanel x:Name="TrendSparklines"/>
                            </StackPanel>
                        </Border>

                        <!-- Feature breakdown donut -->
                        <Border Background="#10F5F7FA" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Breakdown of how you spent your time across features.">
                            <StackPanel>
                                <TextBlock Text="FEATURE BREAKDOWN" FontSize="9" FontWeight="SemiBold" Foreground="#80B6C3CA" Margin="0,0,0,6"/>
                                <Canvas x:Name="FeatureDonutCanvas" Height="130" ClipToBounds="True"/>
                                <StackPanel x:Name="FeatureDonutLegend" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Activity Flow (feature transitions) -->
                        <Border Background="#10F5F7FA" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="How you move between features during sessions.">
                            <StackPanel>
                                <TextBlock Text="ACTIVITY FLOW" FontSize="9" FontWeight="SemiBold" Foreground="#80B6C3CA" Margin="0,0,0,6"/>
                                <Canvas x:Name="ActivityFlowCanvas" Height="120" ClipToBounds="True"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Right column: top queries, top projects, widget usage, session timeline -->
                <ScrollViewer Grid.Column="2" Style="{StaticResource ThinScrollViewer}" Margin="4,0,0,0">
                    <StackPanel>
                        <!-- Top queries -->
                        <Border Background="#10F5F7FA" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Unique search terms ranked by frequency for this day.">
                            <StackPanel>
                                <TextBlock Text="TOP QUERIES" FontSize="9" FontWeight="SemiBold" Foreground="#80B6C3CA" Margin="0,0,0,6"/>
                                <StackPanel x:Name="TopQueriesPanel"/>
                            </StackPanel>
                        </Border>

                        <!-- Top projects -->
                        <Border Background="#10F5F7FA" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Most accessed projects in the last 7 days.">
                            <StackPanel>
                                <TextBlock Text="TOP PROJECTS (7d)" FontSize="9" FontWeight="SemiBold" Foreground="#80B6C3CA" Margin="0,0,0,6"/>
                                <StackPanel x:Name="TopProjectsPanel"/>
                            </StackPanel>
                        </Border>

                        <!-- Widget usage breakdown -->
                        <Border Background="#10F5F7FA" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Total events recorded per widget for this day.">
                            <StackPanel>
                                <TextBlock Text="WIDGET USAGE" FontSize="9" FontWeight="SemiBold" Foreground="#80B6C3CA" Margin="0,0,0,6"/>
                                <StackPanel x:Name="WidgetUsageRows"/>
                            </StackPanel>
                        </Border>

                        <!-- Session timeline -->
                        <Border Background="#10F5F7FA" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                ToolTip="Individual sessions with duration and actions.">
                            <StackPanel>
                                <TextBlock Text="SESSION TIMELINE" FontSize="9" FontWeight="SemiBold" Foreground="#80B6C3CA" Margin="0,0,0,6"/>
                                <StackPanel x:Name="SessionTimelinePanel"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Admin multi-user view (hidden by default, shown in admin builds) -->
            <Grid x:Name="AdminViewPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Admin header + date range -->
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#15FF9800" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ADMIN" FontSize="9" FontWeight="Bold" Foreground="#FFB74D" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="AdminUserCountLabel" Text="All users" FontSize="10" Foreground="#B6C3CA" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#10F5F7FA" CornerRadius="4" Padding="6,3" Cursor="Hand" MouseLeftButtonDown="AdminPrevRange_Click">
                        <TextBlock Text="&#x25C0;" FontSize="10" Foreground="#B6C3CA" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="AdminDateRangeLabel" Grid.Column="3" Text="Last 7 days" FontSize="11" FontWeight="Medium" Foreground="#F5F7FA" VerticalAlignment="Center" Margin="8,0"/>
                    <Border Grid.Column="4" Background="#10F5F7FA" CornerRadius="4" Padding="6,3" Cursor="Hand" MouseLeftButtonDown="AdminNextRange_Click">
                        <TextBlock Text="&#x25B6;" FontSize="10" Foreground="#B6C3CA" VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <!-- Row 1: User toggle pills (show/hide individual users) -->
                <Border Grid.Row="1" Background="#08F5F7FA" CornerRadius="6" Padding="10,6" Margin="0,0,0,6">
                    <StackPanel>
                        <TextBlock Text="USERS (click to toggle)" FontSize="8" FontWeight="SemiBold" Foreground="#80B6C3CA" Margin="0,0,0,4"/>
                        <WrapPanel x:Name="UserTogglePanel" Orientation="Horizontal"/>
                    </StackPanel>
                </Border>

                <!-- Row 2: Metric selectors (dynamic based on chart type) -->
                <Border x:Name="MetricSelectorBorder" Grid.Row="2" Background="#08F5F7FA" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                    <StackPanel x:Name="MetricSelectorPanel"/>
                </Border>

                <!-- Row 3: Chart type selector -->
                <Border Grid.Row="3" Background="#08F5F7FA" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                    <WrapPanel x:Name="ChartTypeButtons" Orientation="Horizontal"/>
                </Border>

                <!-- Row 4: Main content — three columns: chart, user summary, activity flow/projects -->
                <Grid Grid.Row="4" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Chart canvas -->
                    <Border Grid.Column="0" Background="#08F5F7FA" CornerRadius="6" Padding="8" Margin="0,0,4,0">
                        <Grid>
                            <Canvas x:Name="ChartCanvas" ClipToBounds="True"/>
                            <TextBlock x:Name="ChartEmptyLabel" Text="Select a chart type above" FontSize="11" FontStyle="Italic"
                                       Foreground="#6B7A85" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- User summary (middle) -->
                    <Border Grid.Column="1" Background="#10F5F7FA" CornerRadius="6" Padding="10,8" Margin="4,0,4,0">
                        <ScrollViewer Style="{StaticResource ThinScrollViewer}">
                            <StackPanel>
                                <TextBlock Text="USER SUMMARY" FontSize="9" FontWeight="SemiBold" Foreground="#80B6C3CA" Margin="0,0,0,6"/>
                                <StackPanel x:Name="AdminSummaryRows"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- Admin insights (right) -->
                    <ScrollViewer Grid.Column="2" Style="{StaticResource ThinScrollViewer}" Margin="4,0,0,0">
                        <StackPanel>
                            <!-- Admin activity flow -->
                            <Border Background="#10F5F7FA" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="ACTIVITY FLOW" FontSize="9" FontWeight="SemiBold" Foreground="#80B6C3CA" Margin="0,0,0,6"/>
                                    <Canvas x:Name="AdminFlowCanvas" Height="120" ClipToBounds="True"/>
                                </StackPanel>
                            </Border>

                            <!-- Admin top projects -->
                            <Border Background="#10F5F7FA" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="TOP PROJECTS" FontSize="9" FontWeight="SemiBold" Foreground="#80B6C3CA" Margin="0,0,0,6"/>
                                    <StackPanel x:Name="AdminTopProjectsPanel"/>
                                </StackPanel>
                            </Border>

                            <!-- Admin feature breakdown -->
                            <Border Background="#10F5F7FA" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="FEATURE USAGE" FontSize="9" FontWeight="SemiBold" Foreground="#80B6C3CA" Margin="0,0,0,6"/>
                                    <StackPanel x:Name="AdminFeatureRows"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
