<UserControl x:Class="DesktopHub.UI.Widgets.CheatSheetWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch"
             Background="Transparent">
    
    <UserControl.Resources>
        <!-- Widget-specific semantic brushes -->
        <SolidColorBrush x:Key="AccentDimBrush" Color="#80619EFF"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="{DynamicResource TextSecondaryColor}"/>
        <SolidColorBrush x:Key="DimTextBrush" Color="{DynamicResource TextSecondaryColor}"/>
        <SolidColorBrush x:Key="TableHeaderBrush" Color="{DynamicResource HoverColor}"/>
        <SolidColorBrush x:Key="TableRowAltBrush" Color="{DynamicResource FaintOverlayColor}"/>
        <SolidColorBrush x:Key="InputHighlightBrush" Color="{DynamicResource InputHighlightColor}"/>
        <SolidColorBrush x:Key="OutputHighlightBrush" Color="{DynamicResource OutputHighlightColor}"/>
        <SolidColorBrush x:Key="MatchHighlightBrush" Color="{DynamicResource MatchHighlightColor}"/>
        
        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid SnapsToDevicePixels="True" Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Margin="1,2,1,2">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{DynamicResource ScrollbarThumbBrush}" CornerRadius="3" MinHeight="20"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="6"/>
                                <Setter Property="Width" Value="Auto"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="2,1,2,1"/>
                                <Setter TargetName="Thumb" Property="Width" Value="20"/>
                            </Trigger>
                            <Trigger SourceName="Thumb" Property="IsMouseOver" Value="True">
                                <Setter TargetName="Thumb" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- ComboBoxItem dark style (matches SearchOverlay year selector) -->
        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2,1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="6"
                                Padding="10,6"
                                Margin="0">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverMediumBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox dark style -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SelectedBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="templateRoot" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition MinWidth="0" Width="0"/>
                            </Grid.ColumnDefinitions>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Grid.ColumnSpan="2"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PopupAnimation="{DynamicResource {x:Static SystemParameters.ComboBoxPopupAnimationKey}}">
                                <Border x:Name="dropDownBorder"
                                        Background="{DynamicResource SurfaceSolidBrush}"
                                        BorderBrush="{DynamicResource SelectedBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinWidth="{Binding ActualWidth, ElementName=templateRoot}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True" VerticalScrollBarVisibility="Hidden">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"
                                                    RenderOptions.ClearTypeHint="Enabled"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                            <ToggleButton x:Name="toggleButton"
                                          Grid.ColumnSpan="2"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="OverridesDefaultStyle" Value="True"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="20"/>
                                                            </Grid.ColumnDefinitions>
                                                            <ContentPresenter Grid.Column="0"
                                                                              Margin="8,5,0,5"
                                                                              VerticalAlignment="Center"
                                                                              HorizontalAlignment="Left"/>
                                                            <Path Grid.Column="1"
                                                                  Data="M 0 0 L 4 4 L 8 0 Z"
                                                                  Fill="{DynamicResource TextSecondaryBrush}"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource HoverMediumBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                            <ContentPresenter x:Name="contentPresenter"
                                              Grid.Column="0"
                                              Margin="8,5,24,5"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        <Setter Property="FontSize" Value="12"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header row: Title + discipline dropdown -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Cheat Sheets"
                          FontSize="14"
                          FontWeight="SemiBold"
                          Foreground="{DynamicResource TextBrush}"/>
                <TextBlock x:Name="CodeBookLabel"
                          FontSize="10"
                          Foreground="{DynamicResource MutedTextBrush}"
                          Margin="0,2,0,0"/>
            </StackPanel>
            
            <ComboBox x:Name="DisciplineCombo"
                     Grid.Column="1"
                     Width="140"
                     Cursor="Hand"
                     Style="{StaticResource DarkComboBox}"
                     SelectionChanged="DisciplineCombo_SelectionChanged">
                <ComboBoxItem Content="Electrical" IsSelected="True"/>
                <ComboBoxItem Content="Mechanical"/>
                <ComboBoxItem Content="Plumbing"/>
                <ComboBoxItem Content="Fire Protection"/>
            </ComboBox>
        </Grid>
        
        <!-- Main content area -->
        <Grid Grid.Row="1">
            <!-- State: Sheet list (browse/search view) -->
            <Grid x:Name="SheetListPanel" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Search box -->
                <Border Grid.Row="0"
                        Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="6"
                        Padding="8,6"
                        Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#128269;" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource MutedTextBrush}"/>
                        <TextBox x:Name="SearchBox"
                                Grid.Column="1"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{DynamicResource TextBrush}"
                                CaretBrush="{DynamicResource TextBrush}"
                                FontSize="12"
                                VerticalAlignment="Center"
                                TextChanged="SearchBox_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Grid>
                                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="Placeholder"
                                                              Text="Search cheat sheets..."
                                                              Foreground="{DynamicResource TextPlaceholderBrush}"
                                                              FontSize="12"
                                                              VerticalAlignment="Center"
                                                              IsHitTestVisible="False"
                                                              Visibility="Collapsed"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <Border Grid.Column="2"
                                x:Name="ClearSearchButton"
                                Visibility="Collapsed"
                                Background="Transparent"
                                CornerRadius="3"
                                Padding="4,2"
                                Cursor="Hand"
                                MouseLeftButtonDown="ClearSearchButton_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource HoverMediumBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="&#10005;" FontSize="10" Foreground="{DynamicResource MutedTextBrush}"/>
                        </Border>
                    </Grid>
                </Border>
                
                <!-- Jurisdiction info bar -->
                <Border x:Name="JurisdictionBar"
                        Grid.Row="1"
                        Visibility="Collapsed"
                        Background="{DynamicResource GoldBackgroundBrush}"
                        CornerRadius="4"
                        Padding="8,4"
                        Margin="0,0,0,6">
                    <TextBlock x:Name="JurisdictionLabel"
                              FontSize="10"
                              Foreground="{DynamicResource GoldDarkBrush}"
                              TextWrapping="Wrap"/>
                </Border>
                
                <!-- Sheet list -->
                <ScrollViewer Grid.Row="2"
                             VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBar}"/>
                    </ScrollViewer.Resources>
                    <StackPanel x:Name="SheetListItems"/>
                </ScrollViewer>
                
                <!-- Empty state -->
                <Border x:Name="EmptyState"
                        Grid.Row="2"
                        Visibility="Collapsed"
                        Padding="0,20">
                    <StackPanel>
                        <TextBlock Text="No cheat sheets found in this discipline"
                                  FontSize="12"
                                  Foreground="{DynamicResource MutedTextBrush}"
                                  HorizontalAlignment="Center"/>

                        <!-- Cross-discipline results -->
                        <Border x:Name="CrossDisciplinePanel"
                                Visibility="Collapsed"
                                Background="{DynamicResource GoldBackgroundBrush}"
                                CornerRadius="6"
                                Padding="10,8"
                                Margin="0,12,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                              Text="FOUND IN OTHER DISCIPLINES"
                                              FontSize="9"
                                              FontWeight="SemiBold"
                                              Foreground="{DynamicResource GoldDarkBrush}"
                                              VerticalAlignment="Center"/>
                                    <Border Grid.Column="1"
                                            x:Name="CrossDisciplineToggle"
                                            Background="Transparent"
                                            CornerRadius="3"
                                            Padding="6,2"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="CrossDisciplineToggle_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource GoldBackgroundBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock x:Name="CrossDisciplineToggleLabel"
                                                  Text="Hide"
                                                  FontSize="9"
                                                  Foreground="{DynamicResource GoldDarkBrush}"/>
                                    </Border>
                                </Grid>
                                <StackPanel x:Name="CrossDisciplineItems"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
                
                <!-- Footer -->
                <Border Grid.Row="3"
                        Margin="0,8,0,0"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="0,6,0,0">
                    <TextBlock x:Name="SheetCountLabel"
                              Text="0 sheets"
                              FontSize="10"
                              Foreground="{DynamicResource MutedTextBrush}"/>
                </Border>
            </Grid>
            
            <!-- State: Sheet detail (table/calculator/note view) -->
            <Grid x:Name="SheetDetailPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Row 0: Back + title + view mode toggle -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0"
                            x:Name="BackButton"
                            Background="Transparent"
                            CornerRadius="4"
                            Padding="6,3"
                            Cursor="Hand"
                            Margin="0,0,8,0"
                            VerticalAlignment="Top"
                            MouseLeftButtonDown="BackButton_Click">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="&#8592;" FontSize="14" Foreground="{DynamicResource AccentBrush}"/>
                    </Border>
                    
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="DetailTitle"
                                  FontSize="13"
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource TextBrush}"
                                  TextWrapping="Wrap"/>
                        <TextBlock x:Name="DetailSubtitle"
                                  FontSize="10"
                                  Foreground="{DynamicResource DimTextBrush}"
                                  Margin="0,2,0,0"
                                  TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- View mode toggle: Lookup / Table -->
                    <Border Grid.Column="2"
                            x:Name="ViewModeToggle"
                            Visibility="Collapsed"
                            Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="4"
                            Padding="10,4,10,4"
                            MinWidth="78"
                            Cursor="Hand"
                            VerticalAlignment="Top"
                            Margin="6,0,0,0"
                            MouseLeftButtonDown="ViewModeToggle_Click">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock x:Name="ViewModeLabel"
                                  Text="Table"
                                  FontSize="10"
                                  FontWeight="SemiBold"
                                  TextAlignment="Center"
                                  HorizontalAlignment="Center"
                                  Foreground="{DynamicResource AccentBrush}"
                                  TextTrimming="None"/>
                    </Border>
                </Grid>
                
                <!-- Row 1: Steps mode tabs (visible when any sheet has Steps) -->
                <Border x:Name="NoteModeTabs" Grid.Row="1" Visibility="Collapsed" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="NoteTabText" Grid.Column="0" Background="{DynamicResource AccentBrush}" CornerRadius="4,0,0,4"
                                Padding="8,5" Cursor="Hand" MouseLeftButtonDown="NoteTabText_Click">
                            <TextBlock x:Name="NoteTabTextLabel" Text="Table" FontSize="10" FontWeight="SemiBold" Foreground="White"
                                      HorizontalAlignment="Center"/>
                        </Border>
                        <Border x:Name="NoteTabInteractive" Grid.Column="1" Background="{DynamicResource SurfaceBrush}"
                                Padding="8,5" Cursor="Hand" MouseLeftButtonDown="NoteTabInteractive_Click"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,1,0,1">
                            <TextBlock x:Name="NoteTabInteractiveLabel" Text="Interactive" FontSize="10" FontWeight="SemiBold"
                                      Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        </Border>
                        <Border x:Name="NoteTabVisual" Grid.Column="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="0,4,4,0"
                                Padding="8,5" Cursor="Hand" MouseLeftButtonDown="NoteTabVisual_Click">
                            <TextBlock x:Name="NoteTabVisualLabel" Text="Visual" FontSize="10" FontWeight="SemiBold"
                                      Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
                
                <!-- Row 2: Main content area (mode-dependent) -->
                <ScrollViewer Grid.Row="2"
                             x:Name="DetailScroller"
                             VerticalScrollBarVisibility="Hidden"
                             HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <!-- LOOKUP MODE: Input + Output -->
                        <StackPanel x:Name="LookupModePanel" Visibility="Collapsed">
                            <!-- Input area -->
                            <Border x:Name="InputPanel"
                                    Background="{DynamicResource InputHighlightBrush}"
                                    CornerRadius="6"
                                    Padding="10,8"
                                    Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="INPUT"
                                              FontSize="9"
                                              FontWeight="SemiBold"
                                              Foreground="{DynamicResource AccentBrush}"
                                              Margin="0,0,0,6"
                                              Opacity="0.8"/>
                                    <StackPanel x:Name="InputFields"/>
                                    <Border x:Name="LookupButton"
                                            Background="{DynamicResource SurfaceBrush}"
                                            CornerRadius="4"
                                            Padding="10,5"
                                            Margin="0,6,0,0"
                                            Cursor="Hand"
                                            HorizontalAlignment="Left"
                                            MouseLeftButtonDown="LookupButton_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="Lookup" FontSize="11" Foreground="{DynamicResource AccentBrush}"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Output area -->
                            <Border x:Name="OutputPanel"
                                    Visibility="Collapsed"
                                    Background="{DynamicResource OutputHighlightBrush}"
                                    CornerRadius="6"
                                    Padding="10,8"
                                    Margin="0,0,0,0">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                  Text="OUTPUT"
                                                  FontSize="9"
                                                  FontWeight="SemiBold"
                                                  Foreground="{DynamicResource GreenBrush}"
                                                  Opacity="0.8"
                                                  VerticalAlignment="Center"/>
                                        <Border Grid.Column="1"
                                                x:Name="CopyOutputButton"
                                                Background="Transparent"
                                                CornerRadius="3"
                                                Padding="6,2"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="CopyOutputButton_Click">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource GreenBackgroundBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock x:Name="CopyOutputLabel" Text="&#128203; Copy" FontSize="9" Foreground="{DynamicResource GreenBrush}"/>
                                        </Border>
                                    </Grid>
                                    <WrapPanel x:Name="OutputFields" Orientation="Horizontal"/>
                                </StackPanel>
                            </Border>
                            <!-- GEC Parallel Conductor Calculator (shown only for GEC sheet) -->
                            <Border x:Name="GecCalculatorPanel"
                                    Visibility="Collapsed"
                                    Background="{DynamicResource OrangeBackgroundBrush}"
                                    CornerRadius="6"
                                    Padding="10,8"
                                    Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="GEC SIZING CALCULATOR"
                                              FontSize="9"
                                              FontWeight="SemiBold"
                                              Foreground="{DynamicResource OrangeBrush}"
                                              Opacity="0.9"
                                              Margin="0,0,0,6"/>
                                    <TextBlock Text="Per NEC Table 250.66 (single run) and §250.66(B) (parallel sets): select the service conductor size and number of sets to size the GEC."
                                              FontSize="10"
                                              Foreground="{DynamicResource TextSecondaryBrush}"
                                              TextWrapping="Wrap"
                                              Margin="0,0,0,8"/>
                                    <StackPanel x:Name="GecCalcInputFields"/>
                                    <Border x:Name="GecCalcButton"
                                            Background="{DynamicResource SurfaceBrush}"
                                            CornerRadius="4"
                                            Padding="10,5"
                                            Margin="0,6,0,0"
                                            Cursor="Hand"
                                            HorizontalAlignment="Left"
                                            MouseLeftButtonDown="GecCalcButton_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="Calculate GEC" FontSize="11" Foreground="{DynamicResource OrangeBrush}"/>
                                    </Border>
                                    <!-- GEC Calculator output -->
                                    <Border x:Name="GecCalcOutputPanel"
                                            Visibility="Collapsed"
                                            Background="{DynamicResource GreenBackgroundBrush}"
                                            CornerRadius="6"
                                            Padding="10,8"
                                            Margin="0,8,0,0">
                                        <StackPanel>
                                            <TextBlock Text="GEC RESULT"
                                                      FontSize="9"
                                                      FontWeight="SemiBold"
                                                      Foreground="{DynamicResource GreenBrush}"
                                                      Opacity="0.8"
                                                      Margin="0,0,0,6"/>
                                            <WrapPanel x:Name="GecCalcOutputFields" Orientation="Horizontal"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Wire cross-sectional area reference toggle -->
                                    <Border x:Name="GecRefToggleButton"
                                            Background="Transparent"
                                            CornerRadius="4"
                                            Padding="4,4"
                                            Margin="0,10,0,0"
                                            Cursor="Hand"
                                            HorizontalAlignment="Stretch"
                                            MouseLeftButtonDown="GecRefToggle_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                      Text="WIRE CROSS-SECTIONAL AREA REFERENCE"
                                                      FontSize="9"
                                                      FontWeight="SemiBold"
                                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                                      VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                      x:Name="GecRefToggleChevron"
                                                      Text="&#x25BC;"
                                                      FontSize="8"
                                                      Foreground="{DynamicResource TextTertiaryBrush}"
                                                      VerticalAlignment="Center"
                                                      Margin="6,0,0,0"/>
                                        </Grid>
                                    </Border>
                                    <!-- Wire size reference table (collapsible) -->
                                    <Border x:Name="GecRefTablePanel"
                                            Visibility="Collapsed"
                                            Background="{DynamicResource FaintOverlayBrush}"
                                            CornerRadius="6"
                                            Padding="8,6"
                                            Margin="0,4,0,0">
                                        <StackPanel x:Name="GecRefTableRows"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- TABLE MODE: Find bar + table -->
                        <StackPanel x:Name="TableModePanel" Visibility="Collapsed">
                            <!-- Find-in-table bar -->
                            <Border x:Name="FindBar"
                                    Background="{DynamicResource SurfaceBrush}"
                                    CornerRadius="4"
                                    Padding="8,4"
                                    Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#128269;" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox x:Name="FindBox"
                                            Grid.Column="1"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource TextBrush}"
                                            CaretBrush="{DynamicResource TextBrush}"
                                            FontSize="11"
                                            VerticalAlignment="Center"
                                            TextChanged="FindBox_TextChanged">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <Grid>
                                                                <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                                <TextBlock x:Name="Placeholder"
                                                                          Text="Search table..."
                                                                          Foreground="{DynamicResource TextTertiaryBrush}"
                                                                          FontSize="11"
                                                                          VerticalAlignment="Center"
                                                                          IsHitTestVisible="False"
                                                                          Visibility="Collapsed"/>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="Text" Value="">
                                                                    <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <TextBlock x:Name="FindCount"
                                              Grid.Column="2"
                                              FontSize="10"
                                              Foreground="{DynamicResource MutedTextBrush}"
                                              VerticalAlignment="Center"
                                              Margin="6,0,0,0"/>
                                </Grid>
                            </Border>
                            
                            <!-- Table view -->
                            <Grid x:Name="TableView" Visibility="Collapsed">
                                <StackPanel x:Name="TableContainer" HorizontalAlignment="Stretch"/>
                            </Grid>
                        </StackPanel>
                        
                        <!-- NOTE MODE -->
                        <Grid x:Name="NoteView" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border x:Name="NoteTextPanel" Grid.Row="0"
                                    Background="{DynamicResource SurfaceBrush}"
                                    CornerRadius="6"
                                    Padding="12,10"
                                    Margin="0,0,0,8">
                                <TextBlock x:Name="NoteContent"
                                          FontSize="12"
                                          Foreground="{DynamicResource TextBrush}"
                                          TextWrapping="Wrap"
                                          LineHeight="22"/>
                            </Border>
                            <Border x:Name="CopyNoteButton"
                                    Grid.Row="1"
                                    Background="{DynamicResource SurfaceBrush}"
                                    CornerRadius="4"
                                    Padding="10,5"
                                    Cursor="Hand"
                                    HorizontalAlignment="Left"
                                    MouseLeftButtonDown="CopyNoteButton_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock x:Name="CopyNoteLabel" Text="&#128203; Copy" FontSize="11" Foreground="{DynamicResource AccentBrush}"/>
                            </Border>
                        </Grid>
                        
                        <!-- INTERACTIVE MODE (Steps-based, works with any sheet type) -->
                        <StackPanel x:Name="NoteInteractivePanel" Visibility="Collapsed"/>
                        
                        <!-- VISUAL MODE (Steps-based, works with any sheet type) -->
                        <StackPanel x:Name="NoteVisualPanel" Visibility="Collapsed"/>
                    </Grid>
                </ScrollViewer>

                <!-- Row 3: Footer -->
                <Border Grid.Row="3"
                        Margin="0,6,0,0"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="0,6,0,0">
                    <TextBlock x:Name="DetailFooterLabel"
                              FontSize="10"
                              Foreground="{DynamicResource MutedTextBrush}"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
