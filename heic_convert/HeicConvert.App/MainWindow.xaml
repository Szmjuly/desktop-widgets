<Window x:Class="HeicConvert.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HEIC Convert"
        Width="880"
        Height="640"
        MinWidth="720"
        MinHeight="560"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*" MinHeight="200"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="0,0,0,20">
      <TextBlock Text="HEIC Convert" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text}"/>
      <TextBlock Text="Drop HEIC or HEIF files and folders, choose output options, then convert."
                 FontSize="13" Foreground="{StaticResource Brush.Muted}" Margin="0,6,0,0" TextWrapping="Wrap"/>
    </StackPanel>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="300"/>
      </Grid.ColumnDefinitions>

      <!-- Main: drop + queue -->
      <StackPanel Grid.Column="0" Margin="0,0,16,0">
        <Border x:Name="DropZone"
                Style="{StaticResource CardBorder}"
                MinHeight="132"
                Padding="20"
                AllowDrop="True"
                PreviewDragOver="DropZone_OnPreviewDragOver"
                Drop="DropZone_OnDrop">
          <StackPanel VerticalAlignment="Center">
            <Border Width="52" Height="52" CornerRadius="26" Background="#E8F2FC" HorizontalAlignment="Center" Margin="0,0,0,10">
              <TextBlock Text="↓" FontSize="22" Foreground="{StaticResource Brush.Accent}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
            </Border>
            <TextBlock Text="Drop files or folders here" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Text="or use Add… to browse" FontSize="12" Foreground="{StaticResource Brush.Muted}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
          </StackPanel>
        </Border>

        <TextBlock Text="Queue" FontWeight="SemiBold" Margin="0,16,0,8"/>
        <Border Style="{StaticResource CardBorder}" Padding="0">
          <Grid MinHeight="160">
            <ListBox x:Name="QueueList"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            <TextBlock x:Name="QueueEmptyHint"
                       Text="Nothing queued yet."
                       Foreground="{StaticResource Brush.Muted}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False"/>
          </Grid>
        </Border>
      </StackPanel>

      <!-- Settings -->
      <Border Grid.Column="1" Style="{StaticResource CardBorder}" VerticalAlignment="Stretch">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel>
            <TextBlock Text="Settings" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,14"/>

            <TextBlock Text="Output folder" FontSize="12" Foreground="{StaticResource Brush.Muted}" Margin="0,0,0,6"/>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBox x:Name="OutputDirBox" Grid.Column="0"
                       Padding="10,8" VerticalContentAlignment="Center"
                       BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                       Background="White"/>
              <Button x:Name="BrowseOutputBtn" Grid.Column="1" Content="Browse…" Margin="8,0,0,0"
                      Style="{StaticResource SecondaryButton}" Click="BrowseOutput_OnClick"/>
            </Grid>

            <TextBlock Text="Format" FontSize="12" Foreground="{StaticResource Brush.Muted}" Margin="0,16,0,6"/>
            <ComboBox x:Name="FormatCombo" Padding="8,6">
              <ComboBoxItem Content="JPEG (.jpg)" Tag="jpg"/>
              <ComboBoxItem Content="PNG (.png)" Tag="png"/>
            </ComboBox>

            <TextBlock Text="JPEG quality" FontSize="12" Foreground="{StaticResource Brush.Muted}" Margin="0,16,0,6"/>
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <Slider x:Name="QualitySlider" Grid.Row="0" Minimum="1" Maximum="100" TickFrequency="1"
                      IsSnapToTickEnabled="True" ValueChanged="QualitySlider_OnValueChanged"/>
              <TextBlock x:Name="QualityLabel" Grid.Row="1" FontSize="12" Foreground="{StaticResource Brush.Muted}" Margin="0,4,0,0"/>
            </Grid>

            <CheckBox x:Name="RecursiveCheck" Content="Include subfolders" Margin="0,16,0,0"/>
            <CheckBox x:Name="OverwriteCheck" Content="Overwrite existing files" Margin="0,10,0,0"/>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <!-- Footer -->
    <StackPanel Grid.Row="2" Margin="0,20,0,0">
      <ProgressBar x:Name="ProgressBar" Height="6" Minimum="0" Maximum="100" Value="0"
                   Foreground="{StaticResource Brush.Accent}" Background="#E8E8ED" BorderThickness="0"/>
      <Grid Margin="0,12,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="{StaticResource Brush.Muted}" FontSize="13" TextWrapping="Wrap"/>
        <StackPanel Grid.Column="1" Orientation="Horizontal">
          <Button x:Name="AddFilesBtn" Content="Add files…" Style="{StaticResource SecondaryButton}" Click="AddFiles_OnClick" Margin="0,0,8,0"/>
          <Button x:Name="AddFolderBtn" Content="Add folder…" Style="{StaticResource SecondaryButton}" Click="AddFolder_OnClick" Margin="0,0,8,0"/>
          <Button x:Name="ClearBtn" Content="Clear queue" Style="{StaticResource SecondaryButton}" Click="Clear_OnClick" Margin="0,0,8,0"/>
          <Button x:Name="CancelBtn" Content="Cancel" Style="{StaticResource SecondaryButton}" Click="Cancel_OnClick" Margin="0,0,8,0" IsEnabled="False"/>
          <Button x:Name="ConvertBtn" Content="Convert" Click="Convert_OnClick" MinWidth="120"/>
        </StackPanel>
      </Grid>
    </StackPanel>
  </Grid>
</Window>
