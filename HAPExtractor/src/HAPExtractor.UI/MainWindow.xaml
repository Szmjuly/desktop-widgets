<Window x:Class="HAPExtractor.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HAP Extractor"
        Width="1300" Height="850"
        MinWidth="1000" MinHeight="600"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="HAP Extractor"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="24" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="Load Zone Sizing Summary + Space Design Load Summary PDFs to extract and export component loads"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="13" VerticalAlignment="Center"/>
                    <Border Width="12"/>
                    <CheckBox x:Name="SinglePdfModeToggle"
                              Content="Single combined PDF"
                              Style="{StaticResource ToggleSwitchCheckBox}"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              FontSize="12"
                              VerticalAlignment="Center"
                              ToolTip="Enable to drop one merged HAP report PDF (the app will detect which pages belong to each report)."
                              Checked="SinglePdfModeToggle_Changed"
                              Unchecked="SinglePdfModeToggle_Changed"/>
                </StackPanel>
            </StackPanel>
            <Button x:Name="CheckUpdatesButton" Grid.Column="1"
                    Content="Check for Updates"
                    Style="{StaticResource SubtleButton}"
                    Click="CheckUpdates_Click"
                    Padding="12,6" FontSize="11"
                    VerticalAlignment="Top" Margin="8,4,0,0"
                    ToolTip="Check for a newer version"/>
        </Grid>

        <!-- Dual PDF input bar -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                CornerRadius="8" Padding="16" Margin="0,0,0,12"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <StackPanel>
                <!-- Three PDF browse rows (hidden when Single combined PDF is on) -->
                <StackPanel x:Name="PdfInputRowsPanel">
                <!-- PDF 1: Zone Sizing Summary -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock x:Name="Pdf1StatusDot" Text="●" FontSize="10" Margin="0,0,6,0"
                                   Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="Zone Sizing Summary"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="{StaticResource CardBrush}"
                            CornerRadius="5" Padding="10,6" Margin="0,0,8,0"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <TextBlock x:Name="Pdf1PathText"
                                   Text="Not loaded"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center" FontSize="12"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                    <Button Grid.Column="2" Content="Browse"
                            Style="{StaticResource SubtleButton}"
                            Click="BrowsePdf1_Click" Padding="14,6" FontSize="12"/>
                </Grid>
                <Border Height="8"/>

                <!-- PDF 2: Space Design Load Summary -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock x:Name="Pdf2StatusDot" Text="●" FontSize="10" Margin="0,0,6,0"
                                   Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="Space Design Load Summary"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="{StaticResource CardBrush}"
                            CornerRadius="5" Padding="10,6" Margin="0,0,8,0"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <TextBlock x:Name="Pdf2PathText"
                                   Text="Not loaded"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center" FontSize="12"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                    <Button Grid.Column="2" Content="Browse"
                            Style="{StaticResource SubtleButton}"
                            Click="BrowsePdf2_Click" Padding="14,6" FontSize="12"/>
                </Grid>
                <Border Height="8"/>

                <!-- PDF 3: Air System Sizing Summary (optional) -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock x:Name="Pdf3StatusDot" Text="●" FontSize="10" Margin="0,0,6,0"
                                   Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="Air System Sizing Summary"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="(optional)"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="{StaticResource CardBrush}"
                            CornerRadius="5" Padding="10,6" Margin="0,0,8,0"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <TextBlock x:Name="Pdf3PathText"
                                   Text="Not loaded"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center" FontSize="12"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                    <Button Grid.Column="2" Content="Browse"
                            Style="{StaticResource SubtleButton}"
                            Click="BrowsePdf3_Click" Padding="14,6" FontSize="12"/>
                </Grid>
                </StackPanel>

                <Border Height="10"/>

                <!-- Action buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="ProcessButton" Content="Process &amp; Combine"
                            Style="{StaticResource AccentButton}"
                            Click="Process_Click" IsEnabled="False"
                            Padding="20,8" FontSize="13" Margin="0,0,8,0"/>
                    <Button x:Name="ExportExcelButton" Content="Export Excel"
                            Style="{StaticResource SubtleButton}"
                            Click="ExportExcel_Click" IsEnabled="False"
                            Padding="16,8" FontSize="13" Margin="0,0,8,0"/>
                    <Button x:Name="MattsWayButton" Content="Matt's Way"
                            Style="{StaticResource SubtleButton}"
                            Click="ExportMattsWay_Click" IsEnabled="False"
                            Padding="16,8" FontSize="13"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Results info card -->
        <Border Grid.Row="2" x:Name="ResultsInfoCard"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="8" Padding="14" Margin="0,0,0,10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Project:"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="ProjectNameText"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,24,0"/>
                <TextBlock Text="Matched Spaces:"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="MatchedCountText"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main content area -->
        <Grid Grid.Row="3" x:Name="ResultsPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Mode tabs + search bar (always visible) -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8" Padding="8,6" Margin="0,0,0,8"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button x:Name="ModeAllButton" Content="All"
                                Style="{StaticResource AccentButton}"
                                Click="ModeAll_Click" Padding="14,6" FontSize="11" Margin="0,0,4,0"/>
                        <Button x:Name="ModeSystemButton" Content="Systems"
                                Style="{StaticResource SubtleButton}"
                                Click="ModeSystem_Click" Padding="14,6" FontSize="11" Margin="0,0,4,0"/>
                        <Button x:Name="ModeZoneButton" Content="Zones"
                                Style="{StaticResource SubtleButton}"
                                Click="ModeZone_Click" Padding="14,6" FontSize="11"/>
                    </StackPanel>

                    <!-- Search box -->
                    <Border Grid.Column="1" x:Name="SearchBar" Margin="12,0,0,0"
                            Background="{StaticResource CardBrush}" CornerRadius="4"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Padding="8,4" Width="200" Visibility="Collapsed">
                        <TextBox x:Name="SearchBox"
                                 Background="Transparent"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderThickness="0" FontSize="12"
                                 TextChanged="SearchBox_TextChanged"
                                 VerticalAlignment="Center">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}"/>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Border>

                    <TextBlock Grid.Column="3" x:Name="DataGridHeaderText"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Sidebar + DataGrid split -->
            <Grid Grid.Row="1" x:Name="SidebarGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Sidebar (hidden in All mode) -->
                <Border Grid.Column="0" x:Name="SidebarBorder" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="8" Margin="0,0,10,0"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Visibility="Collapsed">
                    <ListBox x:Name="SidebarList"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             SelectionChanged="SidebarList_SelectionChanged"
                             Padding="6">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="Transparent"
                                                    CornerRadius="4" Margin="2,1">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                        <Condition Property="IsSelected" Value="False"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource CardBrush}"/>
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Border>

                <!-- Right: DataGrid (multi-zone) -->
                <Border Grid.Column="1" x:Name="DataGridPanel" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <DataGrid x:Name="CombinedDataGrid"
                              Style="{StaticResource DarkDataGrid}"
                              ColumnHeaderStyle="{StaticResource DarkColumnHeader}"
                              CellStyle="{StaticResource DarkDataGridCell}"
                              RowStyle="{StaticResource DarkDataGridRow}"
                              Margin="1"
                              CanUserSortColumns="False"
                              HorizontalScrollBarVisibility="Auto"
                              ColumnWidth="SizeToCells"/>
                </Border>

                <!-- Right: Single-zone card view -->
                <Border Grid.Column="1" x:Name="SingleZonePanel" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel x:Name="SingleZoneContent" Margin="0,0,0,16"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- Empty state -->
        <Border Grid.Row="3" x:Name="EmptyState"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="12"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="2"
                AllowDrop="True" DragOver="EmptyState_DragOver" Drop="EmptyState_Drop">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets"
                           FontSize="48" HorizontalAlignment="Center"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>
                <TextBlock Text="Drop both PDFs here, or use Browse above"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="16" HorizontalAlignment="Center"/>
                <TextBlock Text="1. Zone Sizing Summary  ·  2. Space Design Load Summary  ·  3. Air System Sizing Summary (optional)"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12" HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="4" Margin="0,10,0,0" Padding="8,6"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" x:Name="StatusText"
                           Text="Ready — load both PDFs to begin"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12"/>

                <ProgressBar Grid.Row="2"
                             x:Name="ProcessingProgressBar"
                             Style="{StaticResource SlimAccentProgressBar}"
                             Minimum="0" Maximum="100"
                             Value="0"
                             Visibility="Collapsed"
                             IsIndeterminate="True"/>
            </Grid>
        </Border>
    </Grid>
</Window>
